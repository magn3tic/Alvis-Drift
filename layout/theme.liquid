<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <meta name="description" content="{{ page_description }}">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" sizes="32x32" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    </title>

    {% render 'meta-tags' %}

    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="dns-prefetch" href="https://connect.facebook.net">
    <link rel="dns-prefetch" href="https://static.klaviyo.com">
    {%- comment -%}theme-check-enable RemoteAsset{%- endcomment -%}

    <script src="{{ 'global.js' | asset_url }}" defer></script>
    <script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>

    {{ content_for_header }}

    {% style %}
    :root {
      --font-body-family: 'Metropolis', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      --font-heading-family: 'Moriarty', 'Metropolis', system-ui, sans-serif;
      --font-body-style: normal;
      --font-body-weight: 400;
      --font-heading-style: normal;
      --font-heading-weight: 600;
      --font-body-scale: {{ settings.body_scale | divided_by: 100.0 }};
      --font-heading-scale: {{ settings.heading_scale | times: 1.0 | divided_by: settings.body_scale }};
      --color-base-text: {{ settings.colors_text.red }}, {{ settings.colors_text.green }}, {{ settings.colors_text.blue }};
      --color-base-background-1: {{ settings.colors_background_1.red }}, {{ settings.colors_background_1.green }}, {{ settings.colors_background_1.blue }};
      --color-base-background-2: {{ settings.colors_background_2.red }}, {{ settings.colors_background_2.green }}, {{ settings.colors_background_2.blue }};
      --color-base-solid-button-labels: {{ settings.colors_solid_button_labels.red }}, {{ settings.colors_solid_button_labels.green }}, {{ settings.colors_solid_button_labels.blue }};
      --color-base-outline-button-labels: {{ settings.colors_outline_button_labels.red }}, {{ settings.colors_outline_button_labels.green }}, {{ settings.colors_outline_button_labels.blue }};
      --color-base-accent-1: {{ settings.colors_accent_1.red }}, {{ settings.colors_accent_1.green }}, {{ settings.colors_accent_1.blue }};
      --color-base-accent-2: {{ settings.colors_accent_2.red }}, {{ settings.colors_accent_2.green }}, {{ settings.colors_accent_2.blue }};
      --payment-terms-background-color: {{ settings.colors_background_1 }};
      --gradient-base-background-1: {% if settings.gradient_background_1 != blank %}{{ settings.gradient_background_1 }}{% else %}{{ settings.colors_background_1 }}{% endif %};
      --gradient-base-background-2: {% if settings.gradient_background_2 != blank %}{{ settings.gradient_background_2 }}{% else %}{{ settings.colors_background_2 }}{% endif %};
      --gradient-base-accent-1: {% if settings.gradient_accent_1 != blank %}{{ settings.gradient_accent_1 }}{% else %}{{ settings.colors_accent_1 }}{% endif %};
      --gradient-base-accent-2: {% if settings.gradient_accent_2 != blank %}{{ settings.gradient_accent_2 }}{% else %}{{ settings.colors_accent_2 }}{% endif %};
      --page-width: {{ settings.page_width | divided_by: 10 }}rem;
      --page-width-margin: {% if settings.page_width == '1600' %}2{% else %}0{% endif %}rem;
    }
    *, *::before, *::after { box-sizing: inherit; }
    html { box-sizing: border-box; font-size: calc(var(--font-body-scale) * 62.5%); height: 100%; }
    body {
      display: grid;
      grid-template-rows: auto auto 1fr auto;
      grid-template-columns: 100%;
      min-height: 100%;
      margin: 0;
      letter-spacing: .02em;
      line-height: calc(1 + 0.8 / var(--font-body-scale));
      font-family: Metropolis;
      font-style: var(--font-body-style);
      font-weight: var(--font-body-weight);
    }
    @media screen and (min-width: 750px) { body { font-size: 1.6rem; } }
    {% endstyle %}

    <!-- ── BLOCKING CSS -->
  {%- unless page.handle == 'the-221-game' or request.path contains 'the-221-game' -%}
  {{ 'font.css' | asset_url | stylesheet_tag: preload: true }}
  {{ 'header-footer.css' | asset_url | stylesheet_tag: preload: true }}
  {{ 'homes.css' | asset_url | stylesheet_tag: preload: true }}
  {%- endunless -%}
  {{ 'main.css' | asset_url | stylesheet_tag: preload: true }}

  <link rel="preload" href="{{ 'styles.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'styles.css' | asset_url }}"></noscript>

    {%- if template.name contains 'blog' -%}
      {{ 'blog.css' | asset_url | stylesheet_tag }}
    {%- endif -%}

    {%- if settings.predictive_search_enabled -%}
      {{ 'component-predictive-search.css' | asset_url | stylesheet_tag: preload: true }}
    {%- endif -%}

    <!-- ── DEFERRED CSS -->

    <link rel="preload" as="style" href="{{ 'venobox.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
    <noscript>{{ 'venobox.css' | asset_url | stylesheet_tag }}</noscript>

    <link rel="preload" as="style" href="{{ 'common_pages_animation.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
    <noscript>{{ 'common_pages_animation.css' | asset_url | stylesheet_tag }}</noscript>

    <link rel="preload" as="style" href="{{ 'custom_css_updates.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
    <noscript>{{ 'custom_css_updates.css' | asset_url | stylesheet_tag }}</noscript>


    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css">

    <script>
    function loadClarity() {
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script","x27i59ltdt");
    }
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadClarity, { timeout: 5000 });
    } else {
      setTimeout(loadClarity, 3000);
    }
    </script>

    <!-- VWO removed: no active experiments, dev subdomain, unused account -->
    <meta name="google-site-verification" content="ARs--uG7rgAn04FtH4Sj2niLmhqBJudZFBT5YbDhkcQ">
  </head>

  <body class="template-{{ template | replace: '.', '-' | replace: '/', '-' }}">
    {% render 'agechecker' %}
    {% section 'announcement-bar' %}
    {% section 'header' %}
    {% render 'cart-mini' %}

    <main class="main-wrapper" role="main" tabindex="-1">
      {{ content_for_layout }}{%- comment -%}theme-check-disable UndefinedObject{%- endcomment -%}{{ locksmith_content_for_layout_addenda }}{%- comment -%}theme-check-enable UndefinedObject{%- endcomment -%}
    </main>

    {% section 'footer' %}

    <ul hidden><li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li></ul>

    <script>
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}'
      };
      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t }}`
      };
      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`
      };
      window.accessibilityStrings = { shareSuccess: `{{ 'general.share.success_message' | t }}` };
    </script>

    {%- comment -%}theme-check-disable RemoteAsset{%- endcomment -%}
    <!-- jQuery: must be first JS, all other scripts depend on it -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js" defer></script>

    <!-- Slick JS: defer is safe — CSS already blocking so styles exist at .slick() call -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js" defer></script>
    {%- comment -%}theme-check-enable RemoteAsset{%- endcomment -%}

    <script src="{{ 'age-gate.js' | asset_url }}" defer></script>
    <script src="{{ 'product-form.js' | asset_url }}" defer></script>
    <script src="{{ 'cart-limit.js' | asset_url }}" defer></script>

    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
    {%- endif -%}

    <script src="{{ 'utils.js' | asset_url }}" defer></script>
    <script src="{{ 'custom-core.js' | asset_url }}" defer></script>

    {%- comment -%}theme-check-disable RemoteAsset{%- endcomment -%}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jQuery.Marquee/1.5.0/jquery.marquee.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/venobox/1.9.3/venobox.min.js" defer></script>
    {%- comment -%}theme-check-enable RemoteAsset{%- endcomment -%}
    <script src="{{ 'custom-marketing.js' | asset_url }}" defer></script>

    {%- if template.name == 'index' or template.name == 'page' or template.name == 'collection' -%}
    <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (!document.querySelector('.parallax-h, .background, .about_background, .parallex_div, .parallex_div2, .parallex_div3, .parallex_div4')) return;
      function loadScript(src, cb) {
        var s = document.createElement('script'); s.src = src;
        s.onload = cb || function(){}; document.body.appendChild(s);
      }
      loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js', function() {
        loadScript('https://cdnjs.cloudflare.com/ajax/libs/ScrollMagic/2.0.3/ScrollMagic.min.js', function() {
          loadScript('https://cdnjs.cloudflare.com/ajax/libs/ScrollMagic/2.0.3/plugins/animation.gsap.min.js', function() {
            loadScript({{ 'custom-parallax.js' | asset_url | json }});
          });
        });
      });
    });
    </script>
    {%- endif -%}

    <script>
    (function() {
      function waitAndRun(attempts) {
        attempts = attempts || 0;
        if (window.jQuery && window.jQuery.fn.slick) {
          var s = document.createElement('script');
          s.src = {{ 'main.js' | asset_url | json }};
          document.body.appendChild(s);
        } else if (attempts < 60) {
          setTimeout(function() { waitAndRun(attempts + 1); }, 100);
        }
      }
      waitAndRun();
    })();
    </script>
    <script>
    (function() {
      var fired = false;
      function loadThirdParty() {
        if (fired) return;
        fired = true;
        function addScript(src) {
          var s = document.createElement('script');
          s.src = src; s.defer = true;
          document.body.appendChild(s);
        }
        if (!window.fbq) {
          addScript('https://connect.facebook.net/en_US/fbevents.js');
        }
        addScript('https://static.klaviyo.com/onsite/js/klaviyo.js?company_id={{ shop.metafields.klaviyo.public_id | default: "" }}');
        {%- if template.name == 'customers/account' or template.name == 'product' -%}
        var loyaltyLoaded = false;
        var lo = new IntersectionObserver(function(e) {
          if (e[0].isIntersecting && !loyaltyLoaded) {
            loyaltyLoaded = true;
            addScript('https://loy.shopapps.site/v2/js/loyaltiesWidget.js?shop={{ shop.permanent_domain }}');
            lo.disconnect();
          }
        }, { rootMargin: '200px' });
        var lt = document.querySelector('#loyalty-widget, .loyalty-widget, [data-loyalty]');
        if (lt) lo.observe(lt);
        {%- endif -%}
      }
      ['pointerdown','touchstart','scroll','keydown'].forEach(function(e) {
        window.addEventListener(e, loadThirdParty, { once: true, passive: true });
      });
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadThirdParty, { timeout: 4000 });
      } else {
        setTimeout(loadThirdParty, 4000);
      }
    })();

    
    </script>

    <!-- External link opener: idle deferred, non-critical -->
    <script>
    function initExternalLinks() {
      var host = window.location.host;
      document.querySelectorAll('a[href]').forEach(function(a) {
        var href = a.getAttribute('href');
        if (!href || /^(#|mailto:|tel:|javascript:)/.test(href)) return;
        try {
          var url = new URL(href, window.location.origin);
          if (url.host && url.host !== host) {
            a.setAttribute('target', '_blank');
            a.setAttribute('rel', 'noopener noreferrer');
          }
        } catch(e) {}
      });
    }
    if ('requestIdleCallback' in window) {
      requestIdleCallback(initExternalLinks);
    } else {
      document.addEventListener('DOMContentLoaded', initExternalLinks);
    }
    </script>

    {% render 'form-popup-notification' %}
  </body>
</html>
