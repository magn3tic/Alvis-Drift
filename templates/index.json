    "page_builder_about_h6d9wM": {
      "type": "page-builder-about",
      "name": "New About Section",
      "settings": {
        "small_heading": "ABOUT ALVI’S DRIFT",
        "heading": "Honest Flavours. Genuine Value.",
        "text": "Since wine’s inception millennia ago, it’s been one of life’s simple pleasures. And we believe that simple pleasure should be accessible (and easy to enjoy) for everyone.<br><br><b>That’s right: no jargon, no fuss. Just wine crafted with care.</b><br><br>We farm sustainably on 410 hectares of cool-climate vineyards, harvest thoughtfully, and let nature take the lead in the cellar. The result? Wines full of character, balance, and real South African soul – at a price that makes sense.<br><br>From weekday dinners to weekend celebrations, Alvi’s Drift gives you wine that overdelivers in every glass.<br><br>No pretence. Just quality. Every time.",
        "button_text": "More About Us",
        "button_link": "shopify://pages/about",
        "video_url": "https://cdn.shopify.com/videos/c/o/v/da3c7f671944436baf206134445180a1.mp4"
      }
    },
    "page_builder_benefits_bUHfcK": {
      "type": "page-builder-benefits",
      "blocks": {
        "benefit_4p4NHY": {
          "type": "benefit",
          "settings": {
            "heading": "People",
            "text": "<p>Behind every bottle are the hands that made it. We support our farm community with fair wages, safe housing, healthcare, and opportunities for growth – because people are our foundation.</p>",
            "link": "shopify://pages/sustainability-people"
          }
        },
        "benefit_Xg3mw9": {
          "type": "benefit",
          "settings": {
            "heading": "Planet",
            "text": "<p>Our land gives us everything – so we farm it with care. From water-wise practices to low-intervention winemaking, sustainability guides every step in the vineyard and cellar.</p>",
            "link": "shopify://pages/sustainability-planet"
          }
        },
        "benefit_68hyYy": {
          "type": "benefit",
          "settings": {
            "heading": "Future",
            "text": "<p>Through our partnership with the Indaba Institute, we invest in what’s next: early childhood education, nutrition programs, and youth development that empowers the next generation to thrive.</p>",
            "link": "shopify://pages/sustainability-future"
          }
        }
      },
      "block_order": [
        "benefit_4p4NHY",
        "benefit_Xg3mw9",
        "benefit_68hyYy"
      ],
      "disabled": true,
      "name": "New Benefits Section",
      "settings": {
        "small_heading": "Sustainability",
        "banner_image": "shopify://shop_images/dare-to-do-right-banner.png"
      }
