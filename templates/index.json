        "range_tab_mPzEAj": {
          "type": "range_tab",
          "settings": {
            "title": "221 Range",
            "description": "Our 221 Range pays homage to the legacy of our founder, Oupa Alvi, who had a legendary rugby career as the 221st player for South Africa’s national team, the Springboks. Bold and contemporary, it blends tradition with modern winemaking, offering vibrant, fruit-forward wines with a stylish edge.",
            "main_image": "shopify://shop_images/wine-221-range.png",
            "link_text": "Shop Range",
            "link_url": "https://alvisdrift.co.za/collections/221-range"
