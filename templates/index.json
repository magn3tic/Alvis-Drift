      "type": "page-builder-tabs",
      "blocks": {
        "range_tab_DgGfTp": {
          "type": "range_tab",
          "settings": {
            "title": "Signature Selection",
            "description": "Whether planned or last-minute, this range gives you more than expected: in taste, value, and the joy of saying yes!",
