{% comment %} PV2 Social Wall — 09 #The221Game Community {% endcomment %}

<section class="pv2-lp section bg-alt grain" id="pv2-social" aria-labelledby="pv2-social-heading">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">08 / The Community</span>
      <h2 class="h2" id="pv2-social-heading" style="margin-top:24px; max-width:1100px;">{% if section.settings.heading != blank %}{{ section.settings.heading | newline_to_br }}{% else %}The game is already<br/>being played.{% endif %}</h2>
      <p class="body" style="max-width:580px; margin-top:24px;">{% if section.settings.subtext != blank %}{{ section.settings.subtext }}{% else %}Real fans. Real stories. Tagged across Instagram and X — pulled in live as they post.{% endif %}</p>
    </div>

    {% if section.settings.embed_code != blank %}
      <div class="reveal" style="margin:56px 0 40px;">
        {{ section.settings.embed_code }}
      </div>
    {% else %}
    <!-- Placeholder grid shown until social wall embed is configured -->
    <div class="social-grid reveal reveal-stagger" id="pv2SocialGrid">
      {% assign placeholder_posts = "DM,Sunday braai '95 jersey glass of 221. Some traditions don't move. #The221Game|KP,My ouma's still louder than the TV. Test match day at her place. #The221Game|TN,Three generations one table one bottle. Connection is our home ground. #The221Game|MB,Pinotage open at 4. Kickoff at 5. Friends through the door at 5:01. #The221Game|RJ,Some stories are written on the field. The best ones are told around it. #The221Game|AS,Game day. Wife asked which jersey. I said which decade. #The221Game" | split: "|" %}
      {% for post in placeholder_posts %}
        {% assign parts = post | split: "," %}
        {% assign initials = parts[0] %}
        {% assign caption = parts[1] %}
        <article class="social-card">
          <div class="social-card-img"></div>
          <div class="social-platform" aria-hidden="true">
            {% if forloop.index0 == 1 or forloop.index0 == 4 %}
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 4l7 8.5L4.5 20H7l5-6 5 6h4l-7.5-9L19 4h-2.5L12 9.5 8 4z"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/></svg>
            {% endif %}
          </div>
          <div class="social-card-body">
            <div class="social-card-head">
              <div class="avatar" aria-hidden="true">{{ initials }}</div>
              <div class="social-card-handle">@user_{{ forloop.index }}</div>
            </div>
            <p class="social-card-caption">{{ caption }}</p>
          </div>
        </article>
      {% endfor %}
    </div>
    {% endif %}

    <div class="center-row reveal">
      <a href="{{ section.settings.hashtag_link | default: '#pv2-submit' }}" class="btn-primary">{% if section.settings.cta_label != blank %}{{ section.settings.cta_label }}{% else %}Join the Conversation — Tag #The221Game{% endif %}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PV2 — Social Wall",
  "settings": [
    { "type": "header",   "content": "Copy" },
    { "type": "textarea", "id": "heading", "label": "Heading",  "default": "The game is already\nbeing played.", "info": "Line breaks become heading line breaks" },
    { "type": "textarea", "id": "subtext", "label": "Subtext",  "default": "Real fans. Real stories. Tagged across Instagram and X — pulled in live as they post." },
    { "type": "text",     "id": "cta_label", "label": "CTA Label", "default": "Join the Conversation — Tag #The221Game" },
    { "type": "header",   "content": "Embed & Link" },
    { "type": "html",     "id": "embed_code",   "label": "Social Wall Embed Code", "info": "Paste embed code from Curator.io, EmbedSocial, or similar. Leave blank to show placeholder grid." },
    { "type": "url",      "id": "hashtag_link", "label": "CTA Link", "info": "Where the CTA button links. Defaults to submission form." }
  ],
  "presets": [{ "name": "PV2 Social Wall" }]
}
{% endschema %}
