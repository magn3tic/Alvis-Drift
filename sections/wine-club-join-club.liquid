<section class="container">
  <script>
      const customerId = window.BOLD?.common?.Shopify?.customer?.id;
      const shopDomain = 'alvis-drift.myshopify.com';
    
      if (customerId) {
    fetch(`/apps/loyalties-widget/v2/${shopDomain}/frontend/customer-tiers-list?shopifyCustomerId=${customerId}`)
      .then(r => r.json())
      .then(data => {
        console.log("Puntos actuales del cliente:", data.points_balance);
      })
      .catch(err => console.error("Error al obtener los puntos:", err));
      } else {
    console.warn("Cliente no autenticado o BOLD no disponible.");
      }
  </script>

</section>
