<style>
  .playbook-footer-strip {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .playbook-footer-strip__inner {
    max-width: 1294px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  /* Shop CTA */
  .playbook-footer-strip__shop {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .playbook-footer-strip__shop-label {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    opacity: 0.5;
    margin: 0;
  }
  .playbook-footer-strip__shop-link {
    background: #c65336;
    color: #fff !important;
    padding: 15px 36px;
    border-radius: 25px;
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: opacity 0.2s;
    display: inline-block;
    white-space: nowrap;
  }
  .playbook-footer-strip__shop-link:hover { opacity: 0.85; }
  /* Hashtag */
  .playbook-footer-strip__hashtag {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(28px, 4vw, 52px);
    color: {{ section.settings.heading_color }};
    font-weight: 400;
    letter-spacing: -0.01em;
    opacity: 0.12;
    margin: 0;
    user-select: none;
  }
  /* Social follows */
  .playbook-footer-strip__socials {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }
  .playbook-footer-strip__socials-label {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    opacity: 0.5;
    margin: 0;
  }
  .playbook-footer-strip__social-links {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .playbook-footer-strip__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid {{ section.settings.heading_color }};
    color: {{ section.settings.heading_color }};
    text-decoration: none;
    transition: all 0.2s;
    opacity: 0.7;
  }
  .playbook-footer-strip__social-link:hover {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
    opacity: 1;
  }
  .playbook-footer-strip__social-link svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
  @media (max-width: 749px) {
    .playbook-footer-strip__inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .playbook-footer-strip__hashtag { display: none; }
    .playbook-footer-strip__socials { align-items: flex-start; }
  }
</style>

<section class="playbook-footer-strip">
  <div class="playbook-footer-strip__inner">
    <div class="playbook-footer-strip__shop">
      {%- if section.settings.shop_label != blank -%}
        <p class="playbook-footer-strip__shop-label">{{ section.settings.shop_label }}</p>
      {%- endif -%}
      {%- if section.settings.shop_cta_text != blank -%}
        <a href="{{ section.settings.shop_link }}" class="playbook-footer-strip__shop-link">{{ section.settings.shop_cta_text }}</a>
      {%- endif -%}
    </div>

    {%- if section.settings.hashtag != blank -%}
      <p class="playbook-footer-strip__hashtag" aria-hidden="true">{{ section.settings.hashtag }}</p>
    {%- endif -%}

    <div class="playbook-footer-strip__socials">
      {%- if section.settings.socials_label != blank -%}
        <p class="playbook-footer-strip__socials-label">{{ section.settings.socials_label }}</p>
      {%- endif -%}
      <div class="playbook-footer-strip__social-links">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="playbook-footer-strip__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" class="playbook-footer-strip__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.x_url != blank -%}
          <a href="{{ section.settings.x_url }}" class="playbook-footer-strip__social-link" target="_blank" rel="noopener" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.737-8.834L2.25 2.25h6.904l4.26 5.639L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}" class="playbook-footer-strip__social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Playbook — Footer Strip",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 8,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 8,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#2e112d"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Icon & Hashtag Colour",
      "default": "#f8f2e6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Label Colour",
      "default": "#f8f2e6"
    },
    {
      "type": "header",
      "content": "Shop CTA"
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Label (small text above button)",
      "default": "The 221 Range"
    },
    {
      "type": "text",
      "id": "shop_cta_text",
      "label": "Button Text",
      "default": "Shop the 221 Range"
    },
    {
      "type": "url",
      "id": "shop_link",
      "label": "Collection Link"
    },
    {
      "type": "header",
      "content": "Campaign Hashtag"
    },
    {
      "type": "text",
      "id": "hashtag",
      "label": "Hashtag",
      "default": "#The221Game"
    },
    {
      "type": "header",
      "content": "Social Follows"
    },
    {
      "type": "text",
      "id": "socials_label",
      "label": "Label",
      "default": "Follow @AlvisDrift"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "x_url",
      "label": "X (Twitter) URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ],
  "presets": [
    { "name": "Playbook — Footer CTA Strip" }
  ]
}
{% endschema %}
