{% comment %} PV3 Nav — loads CSS, fonts, hides theme header/announcement bar {% endcomment %}

{{ 'pv3-styles.css' | asset_url | stylesheet_tag }}

<style>
  /* Font-face declarations using Shopify asset_url */
  @font-face { font-family:"D-DIN"; src:url("{{ 'D-DIN.otf' | asset_url }}") format("opentype"); font-weight:400; font-style:normal; font-display:swap; }
  @font-face { font-family:"D-DIN"; src:url("{{ 'D-DIN-Bold.otf' | asset_url }}") format("opentype"); font-weight:700; font-style:normal; font-display:swap; }
  @font-face { font-family:"D-DIN"; src:url("{{ 'D-DIN-Italic.otf' | asset_url }}") format("opentype"); font-weight:400; font-style:italic; font-display:swap; }
  @font-face { font-family:"D-DIN Condensed"; src:url("{{ 'D-DINCondensed.otf' | asset_url }}") format("opentype"); font-weight:400; font-style:normal; font-display:swap; }
  @font-face { font-family:"D-DIN Condensed"; src:url("{{ 'D-DINCondensed-Bold.otf' | asset_url }}") format("opentype"); font-weight:700; font-style:normal; font-display:swap; }
  @font-face { font-family:"Industry Inc"; src:url("{{ 'IndustryInc-Base.ttf' | asset_url }}") format("truetype"); font-weight:400; font-style:normal; font-display:swap; }
  @font-face { font-family:"Industry Inc Inline"; src:url("{{ 'IndustryInc-Inline.ttf' | asset_url }}") format("truetype"); font-weight:400; font-style:normal; font-display:swap; }
  /* Hide Shopify default header, announcement bar, and site footer on this page */
  #shopify-section-header, #shopify-section-announcement-bar, #shopify-section-footer { display: none !important; }
  /* Ensure page body has no top padding from hidden header */
  body { padding-top: 0 !important; margin-top: 0 !important; }
</style>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ shop.url }}/#organization",
      "name": "Alvi's Drift",
      "url": "{{ shop.url }}",
      "logo": "https:{{ 'alvis-drift-logo.svg' | asset_url }}",
      "sameAs": [
        "https://www.instagram.com/alvisdriftwine/",
        "https://www.facebook.com/AlvisDriftWines",
        "https://x.com/alvisdrift",
        "https://www.tiktok.com/@alvis_drift"
      ]
    },
    {
      "@type": "WebPage",
      "@id": "{{ canonical_url }}",
      "url": "{{ canonical_url }}",
      "name": {{ page_title | json }},
      "description": {{ page_description | json }},
      "inLanguage": "en-ZA",
      "isPartOf": { "@type": "WebSite", "url": "{{ shop.url }}", "name": "Alvi's Drift" },
      "primaryImageOfPage": "https:{{ 'pv3-share-card.jpg' | asset_url }}",
      "publisher": { "@id": "{{ shop.url }}/#organization" }
    },
    {
      "@type": "Event",
      "name": "The 221 Game",
      "description": "Share your greatest rugby moment with #The221Game or the entry form on this page. The best story each week wins a mixed case of 221 Range wine, and every entry qualifies for the R50k grand prize draw, including 2 tickets to the Springboks vs All Blacks match on 5 September 2026.",
      "startDate": "2026-06-05",
      "endDate": "2026-07-31T18:00:00+02:00",
      "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
      "eventStatus": "https://schema.org/EventScheduled",
      "location": { "@type": "VirtualLocation", "url": "{{ canonical_url }}" },
      "image": "https:{{ 'pv3-share-card.jpg' | asset_url }}",
      "organizer": { "@id": "{{ shop.url }}/#organization" },
      "isAccessibleForFree": true
    }
  ]
}
</script>

<header class="pv3-lp pv3-nav" id="pv3-nav" role="banner">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Alvi's Drift">
      <img src="{{ 'alvis-drift-logo.svg' | asset_url }}" class="brand-logo" alt="Alvi's Drift" />
    </a>
    <nav class="nav-links" aria-label="221 Playbook">
      <a href="#pv3-story"    class="nav-link">The Story</a>
      <a href="#pv3-game"     class="nav-link">The Game</a>
      <!--<a href="#pv3-winners"  class="nav-link">Weekly Winners</a>-->
      <a href="#pv3-social"    class="nav-link">The Community</a>
      <a href="#pv3-playbook" class="nav-link">The Playbook</a>
      <a href="#pv3-shop"     class="nav-link">The 221 Range</a>
    </nav>
    <div class="nav-cta-group">
      <a href="#pv3-submit" class="nav-cta" aria-label="Win Weekly — Share your story">
        <span class="nav-cta-end" aria-hidden="true"></span>
        <span class="nav-cta-body"><span>Win Weekly</span><span>Share your story</span></span>
        <span class="nav-cta-end right" aria-hidden="true"></span>
      </a>
      <a href="#pv3-prize" class="nav-cta" aria-label="Win Big — Make a purchase">
        <span class="nav-cta-end" aria-hidden="true"></span>
        <span class="nav-cta-body"><span>Win Big</span><span>Join the Club</span></span>
        <span class="nav-cta-end right" aria-hidden="true"></span>
      </a>
    </div>
    <button class="nav-burger" id="pv3MobileMenuOpen" aria-label="Open menu" aria-expanded="false" aria-controls="pv3MobileMenu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
  </div>
</header>

<!-- Mobile full-screen menu -->
<div class="pv3-mobile-menu" id="pv3MobileMenu" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <div class="pv3-mobile-menu-head">
    <img src="{{ 'alvis-drift-logo.svg' | asset_url }}" alt="Alvi's Drift" style="height:18px;" />
    <button class="pv3-lp pv3-nav nav-burger" id="pv3MobileMenuClose" aria-label="Close menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 5l14 14M19 5L5 19"/></svg>
    </button>
  </div>
  <nav class="pv3-mobile-menu-links" aria-label="Mobile navigation">
    <a href="#pv3-story"    class="pv3-mobile-menu-link" data-mobile-link>The Story</a>
    <a href="#pv3-game"     class="pv3-mobile-menu-link" data-mobile-link>The Game</a>
    <a href="#pv3-prize"    class="pv3-mobile-menu-link" data-mobile-link>The Community</a>
    <!--<a href="#pv3-winners"  class="pv3-mobile-menu-link" data-mobile-link>Weekly Winners</a>-->
    <a href="#pv3-playbook" class="pv3-mobile-menu-link" data-mobile-link>The Playbook</a>
    <a href="#pv3-shop"     class="pv3-mobile-menu-link" data-mobile-link>The 221 Range</a>
  </nav>
  <a href="#pv3-submit" class="pv3-lp btn-primary pv3-mobile-menu-cta" data-mobile-link>Win Weekly | Share your story</a>
  <a href="#pv3-prize" class="pv3-lp btn-primary pv3-mobile-menu-cta" data-mobile-link>Win Big | Join the Club</a>
</div>

<script>
(function() {
  /* --- Nav scroll behaviour (safe to init immediately — nav is in DOM) --- */
  var nav = document.getElementById('pv3-nav');
  function onScroll() { nav.classList.toggle('scrolled', window.scrollY > 80); }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* --- Mobile menu (also safe — menu markup is in pv3-nav section) --- */
  var menu = document.getElementById('pv3MobileMenu');
  var openBtn = document.getElementById('pv3MobileMenuOpen');
  var closeBtn = document.getElementById('pv3MobileMenuClose');
  function openMenu() { menu.classList.add('open'); menu.setAttribute('aria-hidden','false'); openBtn.setAttribute('aria-expanded','true'); }
  function closeMenu() { menu.classList.remove('open'); menu.setAttribute('aria-hidden','true'); openBtn.setAttribute('aria-expanded','false'); }
  if (openBtn) openBtn.addEventListener('click', openMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  document.querySelectorAll('[data-mobile-link]').forEach(function(l) { l.addEventListener('click', closeMenu); });

  /* --- Everything else waits for full DOM so all section elements exist --- */
  document.addEventListener('DOMContentLoaded', function() {

    /* Smooth scroll + active nav */
    var anchors = document.querySelectorAll('a[href^="#pv3-"]');
    anchors.forEach(function(a) {
      a.addEventListener('click', function(e) {
        var id = a.getAttribute('href').slice(1);
        var tgt = document.getElementById(id);
        if (tgt) {
          e.preventDefault();
          window.scrollTo({ top: tgt.getBoundingClientRect().top + window.scrollY - 70, behavior: 'smooth' });
        }
      });
    });

    var navLinks = Array.from(document.querySelectorAll('.pv3-lp.pv3-nav .nav-link'));
    var pageSections = navLinks.map(function(l) {
      return { link: l, target: document.getElementById(l.getAttribute('href').slice(1)) };
    }).filter(function(p) { return p.target; });
    function updateActive() {
      var y = window.scrollY + 100;
      var active = null;
      pageSections.forEach(function(p) { if (p.target.offsetTop <= y) active = p; });
      navLinks.forEach(function(l) { l.classList.remove('active'); });
      if (active) active.link.classList.add('active');
    }
    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();

    /* Scroll-reveal IntersectionObserver (page-wide) */
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
    document.querySelectorAll('.pv3-lp .reveal').forEach(function(el) { io.observe(el); });

    /* Story loading sheen */
    var storyEl = document.getElementById('pv3-story');
    if (storyEl) {
      var sio = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) {
            storyEl.classList.add('is-loading');
            setTimeout(function() { storyEl.classList.remove('is-loading'); }, 2000);
            sio.unobserve(storyEl);
          }
        });
      }, { threshold: 0.18 });
      sio.observe(storyEl);
    }

    /* Mech-card mouse-tracking glow */
    document.querySelectorAll('.pv3-lp .mech-card').forEach(function(card) {
      card.addEventListener('mousemove', function(e) {
        var r = card.getBoundingClientRect();
        card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
        card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
      });
    });

  });
})();
</script>

{% schema %}
{
  "name": "PV3 — Nav",
  "settings": [
    { "type": "text", "id": "cta_label", "label": "CTA Button Label", "default": "Submit Your 221 Moment" },
    { "type": "url",  "id": "cta_link",  "label": "CTA Button Link",  "info": "Default: #pv3-submit (scroll to form)" }
  ],
  "presets": [{ "name": "PV3 Nav" }]
}
{% endschema %}
