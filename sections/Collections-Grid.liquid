{%- comment -%}
  Section: collections-grid-individual.liquid
  - ONLY individual collection tabs (no "All Ranges")
  - First tab active by default
  - Each block/collection has its own product_amount range to limit products shown
{%- endcomment -%}

{% render 'cart-notification' %}

{% if customer.has_account %}
  {% assign lowertags = customer.tags | downcase %}
  {% if lowertags contains 'silver' or lowertags contains 'influencer-silver' %}
    {% assign discount = 0.90 %}
  {% elsif lowertags contains 'gold' %}
    {% assign discount = 0.85 %}
  {% else %}
    {% assign discount = 0.95 %}
  {% endif %}
{% endif %}

<section class="shop-tabs" id="collections-grid-individual">
  <div class="alcontainer">
    {% if section.settings.subtitle_1 != blank or section.settings.topheading != blank %}
      <div class="head">
        {% if section.settings.subtitle_1 != blank %}
          <div class="heading-small">{{ section.settings.subtitle_1 }}</div>
        {% endif %}
        {% if section.settings.topheading != blank %}
          <h3 class="heading">{{ section.settings.topheading }}</h3>
        {% endif %}
      </div>
    {% endif %}

    {%- comment -%} Tabs Nav {%- endcomment -%}
    {% unless section.settings.hide_filter %}
      {% if section.blocks.size > 1 %}
        <div class="stabs">
          <ul>
            {% for block in section.blocks %}
              <li>
                <button
                  type="button"
                  class="tabs-btn {% if forloop.first %}active{% endif %}"
                  data-tab="tab{{ forloop.index }}"
                >
                  {{ block.settings.collection_heading | default: 'Collection' }}
                </button>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% endunless %}

    {%- comment -%} Tabs Content (first active by default) {%- endcomment -%}
    <div class="stabs-content">
      {% for block in section.blocks %}
        {% assign col = collections[block.settings.collectionCarasoul] %}
        {% assign per_collection_limit = block.settings.product_amount | default: 4 %}

        <div data-tab="tab{{ forloop.index }}" class="{% if forloop.first %}active{% endif %}">
          <div class="row">
            {% if col != blank %}
              {% for product in col.products limit: per_collection_limit %}
                {% assign exclude_product_discount = false %}
                {% if product.tags contains 'no-discount-product' %}
                  {% assign exclude_product_discount = true %}
                {% endif %}

                <div class="col-3">
                  <div class="shop-item">
                    <a href="{{ product.url }}">
                      <div class="product-thumb">
                        
                        {% if section.settings.hide_meta_tags == false %}
                         <div class="meta-tag" data-heading="{{ product.metafields.my_fields.wine_range | handleize }}">
                        {{ product.metafields.my_fields.wine_range }}
                      </div>
                      {% endif %}
                        {%- liquid
                        assign product_image_alt = product.featured_image.alt | default: product.title | escape
                      -%}

                      {{
                        product.featured_image
                        | image_url: width: 230, height: 652, crop: 'center'
                        | image_tag:
                          alt: product_image_alt,
                          widths: '115, 160, 217, 230, 326, 434',
                          sizes: '(max-width: 749px) 109px, (max-width: 989px) 160px, 217px',
                          loading: 'lazy',
                          decoding: 'async'
                      }}

                            {% assign member_discount = product.price | times: discount %}
                            {% assign discount_amount = product.price | minus: member_discount | times: -1 %}
                            
                            {% if product.compare_at_price > product.price %}
                              {% assign discount_amount = product.compare_at_price | minus: product.price %}
                              <div class="product-discount">
                                SAVE<br>
                                {{ discount_amount | money_without_trailing_zeros }}
                                {% if product.metafields.my_fields.promo_label.value != blank %}
                                  <p class = "small-text">{{ product.metafields.my_fields.promo_label.value }}</p>
                                {% endif %}
                              </div>
                            {% endif %}

                      </div>
                    </a>

                    <div class="product-add-to-cart">
                      <span>Add to cart</span>
                      <svg fill="none" height="21" viewBox="0 0 22 21" width="22" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11 0C5.225 0 0.5 4.725 0.5 10.5C0.5 16.275 5.225 21 11 21C16.775 21 21.5 16.275 21.5 10.5C21.5 4.725 16.775 0 11 0ZM11 19.725C5.9 19.725 1.775 15.6 1.775 10.5C1.775 5.4 5.9 1.275 11 1.275C16.1 1.275 20.225 5.4 20.225 10.5C20.225 15.6 16.1 19.725 11 19.725Z" fill="white"></path>
                        <path d="M11.6 6.82495H10.4V9.89995H7.625V11.1H10.4V14.325H11.6V11.1H14.45V9.89995H11.6V6.82495Z" fill="white"></path>
                      </svg>

                      <product-form class="product-form">
                        <div class="product-form__error-message-wrapper" role="alert" hidden>
                          <span class="product-form__error-message"></span>
                        </div>

                        {%- form 'product', product, id: product.id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

                          <div class="input-num-wrap">
                            <quantity-input class="">
                              <button type="button" name="plus" class="num-up"></button>
                              <button type="button" name="minus" class="num-down"></button>
                              <input min="1" type="number" id="quantity" name="quantity" class="input-num" max="30" value="1" />
                            </quantity-input>
                          </div>

                          <button
                            type="submit"
                            name="add"
                            class="btn btn-overlay"
                            {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                          >
                            <span>
                              {% if product.selected_or_first_available_variant.available %}
                                BUY
                              {% else %}
                                {{ 'products.product.sold_out' | t }}
                              {% endif %}
                            </span>

                            <div class="loading-overlay__spinner hidden">
                              <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                                <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                              </svg>
                            </div>
                          </button>
                        {%- endform -%}
                      </product-form>
                    </div>

                    <a href="{{ product.url }}">
                      <div class="product-cat">{{ product.title }}</div>
                      {% unless product.tags contains 'Gift' %}
                      <div class="product-price-per">Case of 6</div>
                      {% endunless %}

                      {% if customer %}
                        {% if exclude_product_discount %}
                          {% if product.compare_at_price > product.price %}
                            <div class="product-price">
                              {{ product.price | money_without_trailing_zeros }}
                              <span>WAS <del>{{ product.compare_at_price | money_without_trailing_zeros }}</del></span>
                            </div>
                          {% else %}
                            <div class="product-price">{{ product.price | money_without_trailing_zeros }}</div>
                          {% endif %}
                        {% else %}
                          {% if product.compare_at_price > product.price %}
                            <div class="product-price">
                              {{ product.price | times: discount | money_without_trailing_zeros }}
                              <span>WAS <del>{{ product.compare_at_price | money_without_trailing_zeros }}</del></span>
                            </div>
                          {% else %}
                            <div class="product-price">
                              {{ product.price | times: discount | money_without_trailing_zeros }}
                              <span>WAS <del>{{ product.price | money_without_trailing_zeros }}</del></span>
                            </div>
                          {% endif %}
                        {% endif %}
                      {% else %}
                        {% if product.compare_at_price > product.price %}
                          <div class="product-price">
                            {{ product.price | money_without_trailing_zeros }}
                            <span>WAS <del>{{ product.compare_at_price | money_without_trailing_zeros }}</del></span>
                          </div>
                        {% else %}
                          <div class="product-price rr">{{ product.price | money_without_trailing_zeros }}</div>
                        {% endif %}
                      {% endif %}
                    </a>
                  </div>
                </div>
              {% endfor %}
            {% else %}
              <p>No collection selected for this tab.</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.getElementById('collections-grid-individual');
    if (!section) return;

    const buttons = Array.from(section.querySelectorAll('.tabs-btn'));
    const panes = Array.from(section.querySelectorAll('.stabs-content [data-tab]'));

    if (!buttons.length || !panes.length) return;

    function setActive(tabId) {
      buttons.forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tabId));
      panes.forEach(p => p.classList.toggle('active', p.getAttribute('data-tab') === tabId));
    }

    setActive(buttons[0].dataset.tab);

    buttons.forEach(btn => {
      btn.addEventListener('click', function () {
        setActive(this.dataset.tab);
      });
    });
  });
</script>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "topheading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtitle_1",
      "label": "Sub Heading"
    },
    {
      "type": "checkbox",
      "id": "hide_filter",
      "label": "Hide Filter Tabs",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_meta_tags",
      "label": "Hide Meta Tags",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "item",
      "limit": 16,
      "name": "Choose Collection",
      "settings": [
        {
          "type": "text",
          "id": "collection_heading",
          "label": "Collection Name"
        },
        {
          "type": "collection",
          "id": "collectionCarasoul",
          "label": "Choose Collection"
        },
        {
          "type": "range",
          "id": "product_amount",
          "min": 4,
          "max": 30,
          "step": 1,
          "label": "Products to show",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "category": "Collection",
      "blocks": [
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
