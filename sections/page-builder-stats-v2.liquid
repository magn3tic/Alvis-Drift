<div class="stats-wrap">
  <div class="alcontainer">
    <div class="row">
      <!-- STATS COLUMN -->
      <div class="col-6">
        <ul>
          {% for block in section.blocks %}
            {% if block.type == 'stat' %}
              <li>
                {% if block.settings.number != blank %}
                  <div>{{ block.settings.number }}</div>
                {% endif %}
                {% if block.settings.label != blank %}
                  <span>{{ block.settings.label }}</span>
                {% endif %}
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <!-- CTA COLUMN -->
      <div class="col-6">
        <div class="stats-cta">
          {% if section.settings.heading != blank %}
            <h3 class="h2">{{ section.settings.heading }}</h3>
          {% endif %}
          {% if section.settings.text != blank %}
            <p>{{ section.settings.text }}</p>
          {% endif %}

          <div class="cta-group">
            {% if customer %}
              {% if request.path == '/pages/club' %}
                <a href="/collections/best-sellers" class="cta-btn-lite">SHOP NOW</a>
              {% else %}
                <a href="/pages/club" class="cta-btn-lite">PRIVATE CLUB</a>
              {% endif %}

              <a href="https://alvisdrift.co.za/account" class="cta-btn-border-lite">MY ACCOUNT</a>
            {% else %}
              <a href="https://alvisdrift.co.za/account/register/" class="cta-btn-lite">JOIN OUR PRIVATE CLUB</a>

              <a href="https://alvisdrift.co.za/account/login" class="cta-btn-border-lite">LOGIN</a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  @media(max-width:900px){
    .stats-wrap{
  display: {% if section.settings.hide_on_mobile == true %}none{% else %}block{% endif %}
  }
}
  
  
</style>
{% schema %}
{
  "name": "New Stats",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "CTA Heading",
      "default": "Private wine club"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "CTA Text",
      "default": "Join the Alvi’s Drift Wine Club and <br>receive free shipping for first-time buyers."
    },
    {
      "type": "checkbox",
      "default":false,
      "id": "hide_on_mobile",
      "label": "Hide On Mobile"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Item",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Stat Number",
          "default": "202"
        },
        {
          "type": "textarea",
          "id": "label",
          "label": "Stat Label",
          "default": "Local & International <br>Medals in 2024"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "New Stats Homepage",
      "category": "Content"
    }
  ]
}
{% endschema %}
