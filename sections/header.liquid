<header class="ald-header-wrapper">
  <!-- MAIN HEADER -->
  <div class="ald-header">
    <div class="alcontainer">
      <div class="row align-center">
        {% assign main_menu = linklists[section.settings.main_menu].links %}
        {% assign total_links = main_menu | size %}
        {% assign split_index = 4 %}
        {% assign left_links = main_menu | slice: 0, split_index %}
        {% assign right_links = main_menu | slice: split_index, total_links %}

        <!-- LEFT MENU -->
        <div class="col-5 aldh-left">
          <ul class="menu">
            {% for link in left_links %}
              <li class="{% if link.links != blank %}has-dropdown{% endif %}">
                <a href="{{ link.url }}">{{ link.title }}</a>
                {% if link.links != blank %}
                  <ul class="sub-menu">
                    {% for sublink in link.links %}
                      <li>
                        <a href="{{ sublink.url }}">{{ sublink.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>

        <!-- LOGO -->
        <div class="col-2 text-center">
          <a href="{{ routes.root_url }}" class="logo">
            {% if section.settings.logo != blank %}
              {%- assign logo_height = section.settings.logo.height | times: 300 | divided_by: section.settings.logo.width -%}
              {{
                section.settings.logo
                | image_url: width: 300
                | image_tag:
                  alt: section.settings.logo.alt,
                  width: 300,
                  height: logo_height,
                  fetchpriority: 'high',
                  loading: 'eager'
              }}
            {% else %}
              {{ shop.name }}
            {% endif %}
          </a>
        </div>

        <!-- RIGHT MENU -->
        <div class="col-5 aldh-right">
          <ul class="menu">
            {% for link in right_links %}
              <li class="{% if link.links != blank %}has-dropdown{% endif %}">
                <a href="{{ link.url }}">{{ link.title }}</a>
                {% if link.links != blank %}
                  <ul class="sub-menu">
                    {% for sublink in link.links %}
                      <li>
                        <a href="{{ sublink.url }}">{{ sublink.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>

          {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
            <a href="{{ section.settings.cta_link }}" class="cta-btn-border">{{ section.settings.cta_text }}</a>
          {% else %}
            {% if customer %}
              <a href="https://alvisdrift.co.za/account" class="cta-btn-border">MY ACCOUNT</a>
            {% else %}
              <a href="https://alvisdrift.co.za/account/login" class="cta-btn-border">LOGIN</a>
            {% endif %}
          {% endif %}

          <a href="#" class="header__icon header__icon--cart link focus-inset mini-cart-btn" id="cart-icon-bubble">
            {%- liquid
              if cart == empty
                render 'icon-cart-empty'
              else
                render 'icon-cart'
              endif
            -%}
            <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>

            <div class="cart-count-bubble"{% if cart.total_price == 0 %} style="display:none"{% endif %}>
              <span aria-hidden="true" data-cart-total>{{ cart.total_price | money }}</span>
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </div>
          </a>
        </div>

        <!-- HAMBURGER -->
        <div class="hamburger">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    </div>
  </div>

  <!-- FIXED HEADER -->
  <div class="ald-header ald-header-fixed">
    <div class="alcontainer">
      <div class="row align-center">
        {% assign main_menu = linklists[section.settings.main_menu].links %}
        {% assign total_links = main_menu | size %}
        {% assign split_index = 4 %}
        {% assign left_links = main_menu | slice: 0, split_index %}
        {% assign right_links = main_menu | slice: split_index, total_links %}

        <!-- LEFT MENU -->
        <div class="col-5 aldh-left">
          <ul class="menu">
            {% for link in left_links %}
              <li class="{% if link.links != blank %}has-dropdown{% endif %}">
                <a href="{{ link.url }}">{{ link.title }}</a>
                {% if link.links != blank %}
                  <ul class="sub-menu">
                    {% for sublink in link.links %}
                      <li>
                        <a href="{{ sublink.url }}">{{ sublink.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>

        <!-- LOGO -->
        <div class="col-2 text-center">
          <a href="{{ routes.root_url }}" class="logo">
            {% if section.settings.logo != blank %}
              {% if section.settings.logo != blank %}
              {{
                section.settings.logo
                | image_url: width: 300
                | image_tag:
                  alt: section.settings.logo.alt,
                  widths: '100, 200, 300',
                  sizes: '300px'
              }}
            {% endif %}
                      
            {% else %}
              {{ shop.name }}
            {% endif %}
          </a>
        </div>

        <!-- RIGHT MENU -->
        <div class="col-5 aldh-right">
          <ul class="menu">
            {% for link in right_links %}
              <li class="{% if link.links != blank %}has-dropdown{% endif %}">
                <a href="{{ link.url }}">{{ link.title }}</a>
                {% if link.links != blank %}
                  <ul class="sub-menu">
                    {% for sublink in link.links %}
                      <li>
                        <a href="{{ sublink.url }}">{{ sublink.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
           {% if customer %}
              <a href="https://alvisdrift.co.za/account" class="cta-btn-border my-account-btn">MY ACCOUNT</a>
            {% else %}
              <a href="https://alvisdrift.co.za/account/login" class="cta-btn-border my-account-btn">LOGIN</a>
            {% endif %}
          <a href="#" class="header__icon header__icon--cart link focus-inset mini-cart-btn" id="cart-icon-bubble">
            {%- liquid
              if cart == empty
                render 'icon-cart-empty'
              else
                render 'icon-cart'
              endif
            -%}
            <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>

            <div class="cart-count-bubble"{% if cart.total_price == 0 %} style="display:none"{% endif %}>
              <span aria-hidden="true" data-cart-total>{{ cart.total_price | money }}</span>
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </div>
          </a>

          {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
            <a href="{{ section.settings.cta_link }}" class="cta-btn">{{ section.settings.cta_text }}</a>
          {% endif %}
        </div>
        <div class="hamburger hamburger-2">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    </div>
  </div>

  <!-- MOBILE MENU (uses the same main menu) -->
  <div class="mobile-menu-wrap">
    <div>
      <ul>
        <li>
          {% if customer %}
            <a href="https://alvisdrift.co.za/account">MY ACCOUNT</a>

          {% else %}
            <a href="https://alvisdrift.co.za/account/login">LOGIN</a>
          {% endif %}
        </li>
        {% if template != 'index' %}
          <li><a href="/">HOMEPAGE</a></li>
        {% endif %}
        {% for link in linklists[section.settings.mobile_menu].links %}
          <li class="{% if link.links != blank %}drop-menu{% endif %}">
            {% if link.links != blank %}<span></span>{% endif %}
            <a href="{{ link.url }}">{{ link.title }}</a>
            {% if link.links != blank %}
              <ul>
                {% for sublink in link.links %}
                  <li>
                    <a href="{{ sublink.url }}">{{ sublink.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</header>

<script>
(function () {
  if ({{ cart.total_price | json }} !== 0) return;          
  document.querySelectorAll('.cart-count-bubble').forEach(function (bubble) {
    bubble.style.setProperty('display', 'none', 'important'); 
    var el = bubble.querySelector('[data-cart-total]');
    if (el) el.textContent = '';                              
  });
})();
</script>

<script>
(function () {
  var moneyFormat = {{ shop.money_format | json }};
  var root = (window.Shopify && Shopify.routes && Shopify.routes.root) || '/';
  var lastCents = null;
  var observer = null;
  var syncTimer = null;

  // BOTH headers contain a .cart-count-bubble — grab every one of them.
  function getBubbles() { return document.querySelectorAll('.cart-count-bubble'); }

  function formatMoney(cents) {
    var fmt = moneyFormat;
    var ph = /\{\{\s*(\w+)\s*\}\}/;
    function delim(num, precision, thousands, decimal) {
      thousands = thousands == null ? ',' : thousands;
      decimal = decimal == null ? '.' : decimal;
      if (isNaN(num) || num == null) num = 0;
      num = (num / 100).toFixed(precision);
      var parts = num.split('.');
      var whole = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands);
      return whole + (parts[1] ? decimal + parts[1] : '');
    }
    var m = fmt.match(ph), val = '';
    switch (m && m[1]) {
      case 'amount': val = delim(cents, 2); break;
      case 'amount_no_decimals': val = delim(cents, 0); break;
      case 'amount_with_comma_separator': val = delim(cents, 2, '.', ','); break;
      case 'amount_no_decimals_with_comma_separator': val = delim(cents, 0, '.', ','); break;
      case 'amount_with_apostrophe_separator': val = delim(cents, 2, "'", '.'); break;
      case 'amount_with_space_separator': val = delim(cents, 2, ' ', ','); break;
      default: val = delim(cents, 2);
    }
    return fmt.replace(ph, val);
  }

  // Paint EVERY bubble (main header + fixed header) the same way.
  function paintPrice(cents) {
    getBubbles().forEach(function (bubble) {
      if (cents === 0) {
        bubble.style.setProperty('display', 'none', 'important');
        var z = bubble.querySelector('[data-cart-total]');
        if (z) z.textContent = '';
        return;
      }
      bubble.style.removeProperty('display');
      var el = bubble.querySelector('[data-cart-total]') || bubble.querySelector('[aria-hidden="true"]');
      if (!el) {
        el = document.createElement('span');
        el.setAttribute('aria-hidden', 'true');
        bubble.insertBefore(el, bubble.firstChild);
      }
      el.setAttribute('data-cart-total', '');
      var formatted = formatMoney(cents);
      if (el.textContent !== formatted) el.textContent = formatted;
    });
  }

  // Watch the whole header so we catch the theme re-rendering EITHER cart icon.
  var host = document.querySelector('.ald-header-wrapper')
          || document.querySelector('header')
          || document.body;

  function withObserverPaused(fn) {
    if (observer) observer.disconnect();
    try { fn(); } finally { if (observer && host) observer.observe(host, { childList: true, subtree: true }); }
  }

  function scheduleSync() { clearTimeout(syncTimer); syncTimer = setTimeout(syncCartTotal, 60); }

  async function syncCartTotal() {
    try {
      var res = await fetch(root + 'cart.js', { headers: { Accept: 'application/json' } });
      var cart = await res.json();
      lastCents = cart.total_price;
      withObserverPaused(function () { paintPrice(cart.total_price); });
    } catch (e) {}
  }

  if (host) {
    observer = new MutationObserver(function () {
      if (lastCents != null) withObserverPaused(function () { paintPrice(lastCents); });
      scheduleSync();
    });
    observer.observe(host, { childList: true, subtree: true });
  }

  syncCartTotal();

  if (!window.__cartTotalPoller) {
    window.__cartTotalPoller = setInterval(function () {
      if (document.visibilityState === 'visible') syncCartTotal();
    }, 4000);
  }

  document.addEventListener('visibilitychange', function () {
    if (document.visibilityState === 'visible') syncCartTotal();
  });
})();
</script>

<style>

.cart-count-bubble {
    width: auto;
    border-radius: 5px;
    padding: 0 6px;
    font-size: 11px;
    position: relative;
    bottom: 15px;
    left: 0;
}

@media only screen and (max-width: 1025px) {
    .cart-count-bubble {
        bottom: 13px;
        left: 0;
        position: relative;
    }

}

</style>



{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = shop.url | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ shop.url | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Select Menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Select Mobile Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Explore Wines"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "presets": [
    {
      "name": "Header",
      "category": "Header"
    }
  ]
}
{% endschema %}
