<style>
  .playbook-winners {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .playbook-winners__inner {
    max-width: 1294px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .playbook-winners__header {
    text-align: center;
    margin-bottom: 52px;
  }
  .playbook-winners__eyebrow {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c65336;
    margin-bottom: 14px;
    display: block;
  }
  .playbook-winners__heading {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(30px, 4vw, 54px);
    color: {{ section.settings.heading_color }};
    line-height: 1.05;
    margin: 0;
    font-weight: 400;
  }

  /* Phase placeholder (before first winner announced) */
  .playbook-winners__placeholder {
    text-align: center;
    padding: 60px 20px;
    background: {{ section.settings.card_bg }};
    border-radius: 8px;
    margin-bottom: 40px;
  }
  .playbook-winners__placeholder p {
    font-family: Metropolis, sans-serif;
    font-size: 17px;
    color: {{ section.settings.heading_color }};
    margin: 0;
    opacity: 0.6;
  }

  /* Featured winner */
  .playbook-winners__featured {
    background: {{ section.settings.card_bg }};
    border-radius: 8px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 48px;
  }
  .playbook-winners__featured-image {
    position: relative;
    min-height: 320px;
  }
  .playbook-winners__featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
  }
  .playbook-winners__featured-image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 320px;
    background: linear-gradient(135deg, #480135, #2e112d);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .playbook-winners__featured-image-placeholder span {
    font-family: Metropolis, sans-serif;
    font-size: 12px;
    color: rgba(248,242,230,0.35);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .playbook-winners__featured-content {
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .playbook-winners__winner-badge {
    font-family: Metropolis, sans-serif;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c65336;
    background: rgba(198,83,54,0.12);
    border: 1px solid rgba(198,83,54,0.3);
    border-radius: 20px;
    padding: 5px 14px;
    display: inline-block;
    margin-bottom: 16px;
    align-self: flex-start;
  }
  .playbook-winners__winner-name {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(24px, 3vw, 36px);
    color: {{ section.settings.heading_color }};
    margin: 0 0 6px;
    font-weight: 400;
  }
  .playbook-winners__winner-handle {
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    color: #c65336;
    margin: 0 0 20px;
  }
  .playbook-winners__winner-story {
    font-family: Metropolis, sans-serif;
    font-size: 15px;
    color: {{ section.settings.text_color }};
    line-height: 1.7;
    margin: 0 0 20px;
    flex: 1;
  }
  .playbook-winners__source-note {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    opacity: 0.4;
    margin: 0 0 6px;
  }
  .playbook-winners__prize-confirm {
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    color: #c65336;
    font-weight: 600;
  }

  /* Past winners grid */
  .playbook-winners__grid-heading {
    font-family: Metropolis, sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin-bottom: 24px;
    opacity: 0.5;
  }
  .playbook-winners__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }
  .playbook-winners__card {
    background: {{ section.settings.card_bg }};
    border-radius: 6px;
    padding: 24px;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .playbook-winners__card:hover { transform: translateY(-2px); }
  .playbook-winners__card-handle {
    font-family: Metropolis, sans-serif;
    font-size: 12px;
    color: #c65336;
    margin: 0 0 8px;
    font-weight: 600;
  }
  .playbook-winners__card-excerpt {
    font-family: Metropolis, sans-serif;
    font-size: 14px;
    color: {{ section.settings.text_color }};
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .playbook-winners__card-date {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    color: {{ section.settings.text_color }};
    opacity: 0.4;
    margin-top: 12px;
    display: block;
  }

  /* Footer CTA */
  .playbook-winners__footer {
    text-align: center;
  }
  .playbook-winners__cta {
    background: transparent;
    color: {{ section.settings.heading_color }} !important;
    padding: 15px 38px;
    border-radius: 25px;
    border: 1px solid {{ section.settings.heading_color }};
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
  }
  .playbook-winners__cta:hover { background: rgba(248,242,230,0.08); }

  @media (max-width: 899px) {
    .playbook-winners__featured { grid-template-columns: 1fr; }
    .playbook-winners__featured-image { min-height: 260px; position: relative; }
    .playbook-winners__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 599px) {
    .playbook-winners__grid { grid-template-columns: 1fr; }
    .playbook-winners__featured-content { padding: 28px 20px; }
  }
</style>

<section id="playbook-winners" class="playbook-winners">
  <div class="playbook-winners__inner">
    <div class="playbook-winners__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="playbook-winners__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="playbook-winners__heading">{{ section.settings.heading }}</h2>
    </div>

    {%- assign featured_block = section.blocks | where: "type", "featured_winner" | first -%}
    {%- assign past_blocks = section.blocks | where: "type", "past_winner" -%}

    {%- if featured_block -%}
      <div class="playbook-winners__featured">
        <div class="playbook-winners__featured-image">
          {%- if featured_block.settings.photo != blank -%}
            <img
              src="{{ featured_block.settings.photo | img_url: 'large' }}"
              alt="{{ featured_block.settings.name }}"
              loading="lazy"
            >
          {%- else -%}
            <div class="playbook-winners__featured-image-placeholder">
              <span>Winner photo</span>
            </div>
          {%- endif -%}
        </div>
        <div class="playbook-winners__featured-content">
          <span class="playbook-winners__winner-badge">{{ section.settings.this_week_label }}</span>
          <h3 class="playbook-winners__winner-name">{{ featured_block.settings.name }}</h3>
          {%- if featured_block.settings.handle != blank -%}
            <p class="playbook-winners__winner-handle">{{ featured_block.settings.handle }}</p>
          {%- endif -%}
          <p class="playbook-winners__winner-story">{{ featured_block.settings.story }}</p>
          <p class="playbook-winners__source-note">{{ section.settings.source_label }}</p>
          {%- if featured_block.settings.prize_confirm != blank -%}
            <p class="playbook-winners__prize-confirm">{{ featured_block.settings.prize_confirm }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      <div class="playbook-winners__placeholder">
        <p>{{ section.settings.placeholder_text }}</p>
      </div>
    {%- endif -%}

    {%- if past_blocks.size > 0 -%}
      <p class="playbook-winners__grid-heading">Previous Winners</p>
      <div class="playbook-winners__grid">
        {%- for block in past_blocks -%}
          <div class="playbook-winners__card" {{ block.shopify_attributes }}>
            <p class="playbook-winners__card-handle">{{ block.settings.handle | default: block.settings.name }}</p>
            <p class="playbook-winners__card-excerpt">{{ block.settings.story }}</p>
            {%- if block.settings.date != blank -%}
              <span class="playbook-winners__card-date">{{ block.settings.date }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="playbook-winners__footer">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link | default: '#playbook-form' }}" class="playbook-winners__cta">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Playbook — Weekly Winners",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f2e6"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Colour",
      "default": "#2e112d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text",
      "default": "#3d3d3d"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This Week's 221 Moment."
    },
    {
      "type": "text",
      "id": "this_week_label",
      "label": "Featured Winner Badge Label",
      "default": "This Week's Winner"
    },
    {
      "type": "text",
      "id": "source_label",
      "label": "Source Note",
      "default": "Winner submitted via #The221Game"
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Pre-Launch Placeholder Text",
      "default": "First winner announced 18 June. Check back soon."
    },
    {
      "type": "header",
      "content": "Footer CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Think you can top that? Submit Your Moment."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "blocks": [
    {
      "type": "featured_winner",
      "name": "Featured Winner",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Winner Photo (optional)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Winner Name",
          "default": "Jake van der Merwe"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Social Handle",
          "default": "@jakevm_rugbyfan"
        },
        {
          "type": "textarea",
          "id": "story",
          "label": "Their 221 Moment",
          "default": "My dad drove six hours to watch the Boks vs All Blacks in 1995. He brought one beer — a bottle of 221. I was seven. I still have the bottle."
        },
        {
          "type": "text",
          "id": "prize_confirm",
          "label": "Prize Confirmation",
          "default": "A box of 221 is on its way."
        }
      ]
    },
    {
      "type": "past_winner",
      "name": "Past Winner",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Winner Name",
          "default": "Past Winner"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Social Handle",
          "default": "@handle"
        },
        {
          "type": "textarea",
          "id": "story",
          "label": "Story Excerpt",
          "default": "Their greatest rugby moment — a short excerpt of the winning story."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Week Label",
          "default": "Week of 18 June"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Playbook — Weekly Winners" }
  ]
}
{% endschema %}
