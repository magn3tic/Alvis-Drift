<section class="awc-hero-v2">


  <div class="awc-hero--content-v2">
    <h1 class="h1">Alvi's Drift Wine Club</h1>
    <p>{{ customer_tier }} Tier Members Portall</p>
    {% assign discount_global = shop.metafields.discount_global %}
    {% assign discount = discount_global.discount %}

    <span>Bronze Discount: {{ discount.tier.bronze }}%</span><br>
    <span>Silver Discount: {{ discount.tier.silver }}%</span><br>
    <span>Gold Discount: {{ discount.tier.gold }}%</span><br>
    <span>Platinum Discount: {{ discount.tier.platinum }}%</span><br>
    <div class="awc-promo--btn">
      <a class="btn" href="/collections/club-{{ customer_tier }}">SHOP NOW</a>
    </div>
  </div>
  <div class="awc-bg awc-bg-picture">
    <picture>
      <source
        media="(max-width: 1023px)"
        srcset="{{ section.settings.image_connected_mobile | image_url: width: 450 }}"
        alt="Alvi's Drift Wine Club">
      <img src="{{ section.settings.image_connected_desktop | image_url: width: 2000 }}" alt="Alvi's Drift Wine Club">
    </picture>
  </div>

{% else %}
  {%- comment -%} User not logged {%- endcomment -%}
  <div class="awc-hero--content-v2">
    <h1 class="h1">Alvi's Drift Wine Club</h1>
    <p>Not a member of the Wine Club yet?</p>
    <div class="awc-promo--btn">
      <a
        class="alvisBtn"
        href="https://alvisdrift.co.za/account/register/"
        target="_blank">JOIN NOW</a>
    </div>
  </div>
  <div class="awc-bg awc-bg-picture awc-bg-picture--disconnected">
    <picture>
      <source
        media="(max-width: 1023px)"
        srcset="{{ section.settings.image_disconnected_mobile | image_url: width: 450 }}"
        alt="Alvi's Drift Wine Club">
      <img src="{{ section.settings.image_disconnected_desktop | image_url: width: 2000 }}" alt="Alvi's Drift Wine Club">
    </picture>
  </div>

</section>


{% schema %}
  {
    "name": "Wine Club Hero V2",
    "settings": [
      {
        "type": "header",
        "content": "🔐 Logged-in User Images"
      },
      {
        "type": "image_picker",
        "id": "image_connected_desktop",
        "label": "Desktop Image (Logged-in)"
      },
      {
        "type": "image_picker",
        "id": "image_connected_mobile",
        "label": "Mobile Image (Logged-in)"
      },
      {
        "type": "header",
        "content": "🚫 Logged-out User Images"
      }, {
        "type": "image_picker",
        "id": "image_disconnected_desktop",
        "label": "Desktop Image (Logged-out)"
      }, {
        "type": "image_picker",
        "id": "image_disconnected_mobile",
        "label": "Mobile Image (Logged-out)"
      }
    ],
    "presets": [
      {
        "name": "Wine Club Hero V2",
        "category": "Custom Sections"
      }
    ]
  }
{% endschema %}