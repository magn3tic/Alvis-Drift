<div class="ald-about">
  <div class="alcontainer">
    {% if section.settings.small_heading != blank %}
      <h3 class="heading-small">{{ section.settings.small_heading }}</h3>
    {% endif %}

    <div class="row">
      <div class="col-4">
       
        {% if section.settings.video_url != blank %}
          {%- assign poster_url = '' -%}
          {%- if section.settings.video_post != blank -%}
            {%- assign poster_url = section.settings.video_post | image_url: width: 800 -%}
          {%- endif -%}
          <video id = "hero-video"
            autoplay muted loop playsinline preload="none" aria-hidden="true"
            {% if poster_url != '' %}poster="{{ poster_url }}"{% endif %}
            style="width:100%;height:auto;display:block;">
            <source data-src="{{ section.settings.video_url }}" type="video/mp4">
          </video>
        {% elsif section.settings.video_post != blank %}
          <img src="{{ section.settings.video_post | image_url: width: 1800 }}" alt="{{ section.settings.heading | escape }}" width="800" loading="lazy">
        {% endif %}
      </div>
      <div class="col-8">
        {% if section.settings.heading != blank %}
          <h4>{{ section.settings.heading }}</h4>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="rte">{{ section.settings.text }}</div>
        {% endif %}

        {% if section.settings.button_text != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="cta-btn-border">{{ section.settings.button_text }}</a>
        {% endif %}

        <hr>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var v = document.getElementById('hero-video');
    if (!v) return;

    // Respect user constraints: no video on data-saver or reduced motion
    if ((navigator.connection && navigator.connection.saveData) ||
        matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    function loadVideo() {
      var s = v.querySelector('source[data-src]');
      if (!s) return;
      s.src = s.dataset.src;
      v.load();
      v.play().catch(function(){});
    }

    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function (entries, obs) {
        if (entries[0].isIntersecting) { loadVideo(); obs.disconnect(); }
      }, { rootMargin: '200px' }).observe(v);
    } else {
      window.addEventListener('load', loadVideo);
    }
  })();
</script>


{% schema %}
{
  "name": "New About Section",
  "settings": [
    {
      "type": "text",
      "id": "small_heading",
      "label": "Top Small Heading",
      "default": "ABOUT ALVI’S DRIFT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Honest Flavours. Genuine Value."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Since its inception millennia ago, it’s been one of life’s simple pleasures. And we believe that simple pleasure should be accessible (and easy to enjoy) for everyone.<br><br>That’s right: no jargon, no fuss – just honest flavours and genuine value.<br><br><strong>Our approach reflects just that.</strong><br><br>We farm sustainably on 410 hectares of cool-climate vineyards, harvest with care, and let nature take the lead in the cellar. The result? Wines full of character, balance, and real South African soul – at a price that makes sense.<br><br>From weekday dinners to weekend celebrations, Alvi’s Drift gives you wine that overdelivers in every glass.<br><br>No pretence. Just quality. Every time."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "More About Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "image_picker",
      "id": "video_post",
      "label": "Video Poster or a fallback Image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Paste a direct MP4 video link. If empty, the uploaded file below will be used."
    }
  ],
  "presets": [
    {
      "name": "New About Section",
      "category": "Content"
    }
  ]
}
{% endschema %}