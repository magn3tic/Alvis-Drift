<style>
  .playbook-story {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .playbook-story__inner {
    max-width: 1294px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .playbook-story__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .playbook-story__layout--image-right .playbook-story__image { order: 2; }
  .playbook-story__layout--image-right .playbook-story__content { order: 1; }
  .playbook-story__content {}
  .playbook-story__eyebrow {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c65336;
    margin-bottom: 16px;
    display: block;
  }
  .playbook-story__heading {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(32px, 4vw, 56px);
    color: {{ section.settings.heading_color }};
    line-height: 1.05;
    margin: 0 0 28px;
    font-weight: 400;
  }
  .playbook-story__body {
    font-family: Metropolis, sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: {{ section.settings.text_color }};
    margin-bottom: 0;
  }
  .playbook-story__body p { margin: 0 0 16px; }
  .playbook-story__body p:last-child { margin-bottom: 0; }
  .playbook-story__quote {
    border-left: 3px solid #c65336;
    padding: 16px 0 16px 24px;
    margin: 32px 0;
  }
  .playbook-story__quote-text {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(18px, 2.2vw, 26px);
    color: {{ section.settings.heading_color }};
    font-style: italic;
    line-height: 1.4;
    margin: 0 0 10px;
    font-weight: 400;
  }
  .playbook-story__quote-attr {
    font-family: Metropolis, sans-serif;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c65336;
    margin: 0;
  }
  .playbook-story__cta {
    display: inline-block;
    margin-top: 32px;
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }
  .playbook-story__cta:hover { opacity: 0.65; }
  .playbook-story__image {
    position: relative;
  }
  .playbook-story__image img {
    width: 100%;
    height: auto;
    display: block;
    clip-path: polygon(0 0,100% 0,100% 92%,0 100%);
  }
  .playbook-story__image-placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    background: linear-gradient(135deg, #480135 0%, #2e112d 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    clip-path: polygon(0 0,100% 0,100% 92%,0 100%);
  }
  .playbook-story__image-placeholder span {
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    color: rgba(248,242,230,0.4);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  @media (max-width: 899px) {
    .playbook-story__layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .playbook-story__layout--image-right .playbook-story__image { order: 1; }
    .playbook-story__layout--image-right .playbook-story__content { order: 2; }
  }
</style>

<section id="playbook-story" class="playbook-story">
  <div class="playbook-story__inner">
    <div class="playbook-story__layout playbook-story__layout--{{ section.settings.image_position }}">
      <div class="playbook-story__content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="playbook-story__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        <h2 class="playbook-story__heading">{{ section.settings.heading }}</h2>

        <div class="playbook-story__body">
          {%- if section.settings.body_1 != blank -%}{{ section.settings.body_1 }}{%- endif -%}
          {%- if section.settings.body_2 != blank -%}{{ section.settings.body_2 }}{%- endif -%}
          {%- if section.settings.body_3 != blank -%}{{ section.settings.body_3 }}{%- endif -%}
        </div>

        {%- if section.settings.quote != blank -%}
          <blockquote class="playbook-story__quote">
            <p class="playbook-story__quote-text">&#8220;{{ section.settings.quote }}&#8221;</p>
            {%- if section.settings.quote_attr != blank -%}
              <p class="playbook-story__quote-attr">— {{ section.settings.quote_attr }}</p>
            {%- endif -%}
          </blockquote>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link }}" class="playbook-story__cta">{{ section.settings.cta_text }}</a>
        {%- endif -%}
      </div>

      <div class="playbook-story__image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | img_url: 'large' }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {%- else -%}
          <div class="playbook-story__image-placeholder">
            <span>Story image</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Playbook — The 221 Story",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "image-right", "label": "Image Right (copy left)" },
        { "value": "image-left", "label": "Image Left (copy right)" }
      ],
      "default": "image-right"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f2e6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Colour",
      "default": "#2e112d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Colour",
      "default": "#3d3d3d"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (small label above heading)",
      "default": "The Heritage"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Before it was a wine, it was a moment."
    },
    {
      "type": "richtext",
      "id": "body_1",
      "label": "Body Paragraph 1",
      "default": "<p>In 1928, Oupa Alvi van der Merwe became Springbok #221 — the first Bok to score a try against the All Blacks on African soil. The number that carried that moment became the name of a wine range.</p>"
    },
    {
      "type": "richtext",
      "id": "body_2",
      "label": "Body Paragraph 2",
      "default": "<p>The 221 range is a tribute to that legacy. Every bottle carries the weight of a try scored in history, and the quiet pride of a family that never forgot where they came from.</p>"
    },
    {
      "type": "richtext",
      "id": "body_3",
      "label": "Body Paragraph 3 (optional)"
    },
    {
      "type": "header",
      "content": "Pull Quote"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Quote Text",
      "default": "The 221 is more than a number. It's a reminder of what's possible when you dare to be true."
    },
    {
      "type": "text",
      "id": "quote_attr",
      "label": "Quote Attribution",
      "default": "Percy Tau"
    },
    {
      "type": "header",
      "content": "Soft CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Link Text",
      "default": "Discover the 221 Range"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story Image"
    }
  ],
  "presets": [
    { "name": "Playbook — The 221 Story" }
  ]
}
{% endschema %}
