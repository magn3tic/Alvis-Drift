{% comment %} PV2 Wine — 07 The Range {% endcomment %}

<section class="pv2-lp section bg-cream" id="pv2-shop" aria-labelledby="pv2-shop-heading">
  <div class="container">
    <div class="wine2-header reveal">
      <span class="eyebrow">07 / The Range</span>
      <h2 class="h2" id="pv2-shop-heading" style="margin-top:24px;">{{ section.settings.heading | default: 'The 221 Range.' }}</h2>
      {% if section.settings.subhead != blank %}
        <p class="body wine2-subhead">{{ section.settings.subhead }}</p>
      {% endif %}
    </div>

    <div class="wine2-grid reveal reveal-stagger">
      {% for block in section.blocks %}
        <article class="wine2-card" {{ block.shopify_attributes }}>
          <div class="wine2-img">
            {% if block.settings.bottle_image %}
              <img src="{{ block.settings.bottle_image | image_url: width: 600 }}" alt="{{ block.settings.wine_name | escape }}" loading="lazy" />
            {% else %}
              <div class="wine2-img-placeholder"><span>Add Bottle Image</span></div>
            {% endif %}
            {% if block.settings.is_percy_pick %}
              <span class="wine2-percy">Percy's Pick</span>
            {% endif %}
          </div>
          <div class="wine2-body">
            {% if block.settings.occasion != blank %}
              <span class="wine2-occasion">{{ block.settings.occasion }}</span>
            {% endif %}
            <h3 class="wine2-name">{{ block.settings.wine_name | default: 'Wine Name' }}</h3>
            {% if block.settings.tasting_note != blank %}
              <p class="wine2-note">{{ block.settings.tasting_note }}</p>
            {% endif %}
            <a href="{{ block.settings.shop_link | default: section.settings.range_link | default: '/collections/221-range' }}" class="wine2-cta">
              {{ section.settings.shop_cta_label | default: 'Shop Now' }}
            </a>
          </div>
        </article>
      {% else %}
        <p class="body" style="grid-column:1/-1;opacity:0.5;">Add wine cards in the Customizer.</p>
      {% endfor %}
    </div>

    {% if section.settings.range_cta_text != blank %}
    <div class="center-row reveal">
      <a href="{{ section.settings.range_link | default: '/collections/221-range' }}" class="btn-primary">{{ section.settings.range_cta_text }}</a>
    </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "PV2 — Wine",
  "settings": [
    { "type": "text",     "id": "heading",       "label": "Heading",           "default": "The 221 Range." },
    { "type": "textarea", "id": "subhead",        "label": "Subheading" },
    { "type": "text",     "id": "shop_cta_label", "label": "Card CTA Label",    "default": "Shop Now" },
    { "type": "header",   "content": "Range Button" },
    { "type": "text",     "id": "range_cta_text", "label": "Range Button Text", "default": "Shop the Full 221 Range →" },
    { "type": "url",      "id": "range_link",     "label": "Range Collection Link" }
  ],
  "blocks": [
    {
      "type": "wine_card",
      "name": "Wine Card",
      "settings": [
        { "type": "image_picker", "id": "bottle_image",  "label": "Bottle Image" },
        { "type": "text",         "id": "occasion",      "label": "Rugby Occasion",     "default": "For The Game." },
        { "type": "text",         "id": "wine_name",     "label": "Wine Name",          "default": "Wine Name" },
        { "type": "textarea",     "id": "tasting_note",  "label": "Tasting Note" },
        { "type": "checkbox",     "id": "is_percy_pick", "label": "Percy's Pick stamp", "default": false },
        { "type": "url",          "id": "shop_link",     "label": "Product Page Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PV2 Wine",
      "blocks": [
        { "type": "wine_card", "settings": { "occasion": "The Pre-Match Build-Up",          "wine_name": "221 Chenin Blanc",       "tasting_note": "Crisp and refreshing with stone fruit and citrus. Light enough for the tension of a pre-match. Ready when you are.",                                                          "is_percy_pick": false } },
        { "type": "wine_card", "settings": { "occasion": "The Opening Whistle",              "wine_name": "221 Sauvignon Blanc",    "tasting_note": "Zesty tropical notes with a clean finish. For the moment the referee raises the whistle and the crowd holds its breath.",                                             "is_percy_pick": true  } },
        { "type": "wine_card", "settings": { "occasion": "The Post-Match Braai",             "wine_name": "221 Pinotage",           "tasting_note": "Rich, smoky and full-bodied. Made for the fire, the meat, and the retelling of a classic try.",                                                                       "is_percy_pick": false } },
        { "type": "wine_card", "settings": { "occasion": "The Moments Worth Remembering",   "wine_name": "221 Special Cuvée Red",  "tasting_note": "Deep and complex — a blend worthy of the most contested rivalry in world rugby. Open when the stakes are highest.",                                                  "is_percy_pick": false } }
      ]
    }
  ]
}
{% endschema %}
