{% comment %} PV2 Hero — video background, badge, CTAs {% endcomment %}

<section class="pv2-lp pv2-hero" id="pv2-top" aria-label="Hero">
  <video class="hero-video" autoplay muted loop playsinline poster="https://cdn.shopify.com/s/files/1/0608/0505/4720/files/Frame_1.png?v=1779495610">
    <source src="{{ section.settings.video_url | default: 'https://cdn.shopify.com/videos/c/o/v/dec4b47f76134f8689ed4d57d20876d1.mp4' }}" type="video/mp4" />
  </video>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="hero-text">
      <span class="hero-eyebrow"><span>#The221Game</span></span>
      <h1 class="hero-h1">{% if section.settings.hero_h1 != blank %}{{ section.settings.hero_h1 | newline_to_br }}{% else %}The 221<br/>Game<br/>is on.{% endif %}</h1>
      <p class="hero-sub">{% if section.settings.hero_sub != blank %}{{ section.settings.hero_sub | newline_to_br }}{% else %}Share your greatest rugby moment.<br/>Win a box of 221. Play The Game.{% endif %}</p>
      <div class="hero-ctas">
        <a href="{{ section.settings.cta_primary_link | default: '#pv2-submit' }}" class="btn-banner">{% if section.settings.cta_primary_label != blank %}{{ section.settings.cta_primary_label }}{% else %}Submit Your 221 Moment{% endif %}</a>
        <a href="{{ section.settings.cta_secondary_link | default: '#pv2-game' }}" class="btn-link">{% if section.settings.cta_secondary_label != blank %}{{ section.settings.cta_secondary_label }}{% else %}How It Works{% endif %}</a>
      </div>
    </div>
    <div class="hero-right">
      {% if section.settings.badge_image %}
        <img class="hero-big-badge" src="{{ section.settings.badge_image | image_url: width: 920 }}" alt="The 221 Game badge" />
      {% else %}
        <img class="hero-big-badge" src="https://cdn.shopify.com/s/files/1/0608/0505/4720/files/Group_9.png?v=1779494749" alt="The 221 Game — Sharing Our Stories — Est. 1928" />
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PV2 — Hero",
  "settings": [
    { "type": "header", "content": "Heading & Copy" },
    { "type": "textarea", "id": "hero_h1",  "label": "Hero Heading",    "default": "The 221\nGame\nis on.",                                           "info": "Each line = one heading line" },
    { "type": "textarea", "id": "hero_sub", "label": "Hero Subheading", "default": "Share your greatest rugby moment.\nWin a box of 221. Play The Game." },
    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "cta_primary_label", "label": "Button Label", "default": "Submit Your 221 Moment" },
    { "type": "url",  "id": "cta_primary_link",  "label": "Button Link",  "info": "Default scrolls to submission form" },
    { "type": "header", "content": "Secondary Link" },
    { "type": "text", "id": "cta_secondary_label", "label": "Link Label",  "default": "How It Works" },
    { "type": "url",  "id": "cta_secondary_link",  "label": "Link Target", "info": "Default scrolls to mechanics section" },
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "badge_image", "label": "Hero Badge Image", "info": "Leave empty to use the default CDN badge" },
    { "type": "text", "id": "video_url", "label": "Hero Video URL", "default": "https://cdn.shopify.com/videos/c/o/v/dec4b47f76134f8689ed4d57d20876d1.mp4", "info": "Direct MP4 URL" }
  ],
  "presets": [{ "name": "PV2 Hero" }]
}
{% endschema %}
