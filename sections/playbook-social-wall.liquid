<style>
  .playbook-social-wall {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .playbook-social-wall__inner {
    max-width: 1294px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .playbook-social-wall__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .playbook-social-wall__eyebrow {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c65336;
    margin-bottom: 14px;
    display: block;
  }
  .playbook-social-wall__heading {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(28px, 4vw, 50px);
    color: {{ section.settings.heading_color }};
    line-height: 1.05;
    margin: 0 0 14px;
    font-weight: 400;
  }
  .playbook-social-wall__subhead {
    font-family: Metropolis, sans-serif;
    font-size: 16px;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    margin: 0;
    line-height: 1.6;
  }
  /* Embed container */
  .playbook-social-wall__embed {
    min-height: 320px;
    margin-bottom: 40px;
  }
  /* Phase placeholder */
  .playbook-social-wall__placeholder {
    background: {{ section.settings.card_bg }};
    border-radius: 8px;
    padding: 80px 40px;
    text-align: center;
    margin-bottom: 40px;
  }
  .playbook-social-wall__placeholder-hashtag {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(36px, 5vw, 72px);
    color: {{ section.settings.heading_color }};
    font-weight: 400;
    margin: 0 0 16px;
    opacity: 0.15;
  }
  .playbook-social-wall__placeholder p {
    font-family: Metropolis, sans-serif;
    font-size: 16px;
    color: {{ section.settings.text_color }};
    opacity: 0.5;
    margin: 0;
  }
  /* Preview grid (manual posts before social wall goes live) */
  .playbook-social-wall__preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  .playbook-social-wall__preview-card {
    aspect-ratio: 1;
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    background: {{ section.settings.card_bg }};
  }
  .playbook-social-wall__preview-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .playbook-social-wall__preview-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.6) 100%);
    display: flex;
    align-items: flex-end;
    padding: 12px;
  }
  .playbook-social-wall__preview-card-handle {
    font-family: Metropolis, sans-serif;
    font-size: 12px;
    color: #fff;
    font-weight: 600;
  }
  .playbook-social-wall__preview-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .playbook-social-wall__preview-placeholder span {
    font-family: Metropolis, sans-serif;
    font-size: 10px;
    color: rgba(248,242,230,0.25);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  /* Footer CTA */
  .playbook-social-wall__footer {
    text-align: center;
  }
  .playbook-social-wall__cta {
    background: transparent;
    color: {{ section.settings.heading_color }} !important;
    padding: 15px 38px;
    border-radius: 25px;
    border: 1px solid {{ section.settings.heading_color }};
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
  }
  .playbook-social-wall__cta:hover {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }} !important;
  }
  @media (max-width: 749px) {
    .playbook-social-wall__preview-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<section id="playbook-social-wall" class="playbook-social-wall">
  <div class="playbook-social-wall__inner">
    <div class="playbook-social-wall__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="playbook-social-wall__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="playbook-social-wall__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subhead != blank -%}
        <p class="playbook-social-wall__subhead">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.embed_code != blank -%}
      <div class="playbook-social-wall__embed">
        {{ section.settings.embed_code }}
      </div>
    {%- elsif section.blocks.size > 0 -%}
      <div class="playbook-social-wall__preview-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'preview_post' -%}
            <div class="playbook-social-wall__preview-card" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | img_url: '600x600', crop: 'center' }}"
                  alt="{{ block.settings.handle }}"
                  loading="lazy"
                >
                <div class="playbook-social-wall__preview-card-overlay">
                  {%- if block.settings.handle != blank -%}
                    <span class="playbook-social-wall__preview-card-handle">{{ block.settings.handle }}</span>
                  {%- endif -%}
                </div>
              {%- else -%}
                <div class="playbook-social-wall__preview-placeholder">
                  <span>Post image</span>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="playbook-social-wall__placeholder">
        <p class="playbook-social-wall__placeholder-hashtag">#The221Game</p>
        <p>{{ section.settings.placeholder_text }}</p>
      </div>
    {%- endif -%}

    <div class="playbook-social-wall__footer">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="playbook-social-wall__cta">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Playbook — Social Wall",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#2e112d"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card / Placeholder Background",
      "default": "#480135"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Colour",
      "default": "#f8f2e6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text",
      "default": "#f8f2e6"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Game is Already Being Played."
    },
    {
      "type": "text",
      "id": "subhead",
      "label": "Subheading",
      "default": "Real moments. Real people. Real 221."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Pre-Launch Placeholder",
      "default": "Social wall activates 5 June once #The221Game gets going. Check back soon."
    },
    {
      "type": "header",
      "content": "Social Wall Embed"
    },
    {
      "type": "textarea",
      "id": "embed_code",
      "label": "Social Wall Embed Code",
      "info": "Paste embed code from Curator, EmbedSocial, Taggbox, or similar. Overrides preview grid when set."
    },
    {
      "type": "header",
      "content": "Footer CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Join the conversation — tag #The221Game"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "blocks": [
    {
      "type": "preview_post",
      "name": "Preview Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Post Image"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Social Handle",
          "default": "@fan_handle"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Playbook — Social Wall" }
  ]
}
{% endschema %}
