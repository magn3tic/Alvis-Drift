      "default": "#f8f2e6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Colour",
      "default": "#2e112d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text",
      "default": "#3d3d3d"
    },
    {
      "type": "color",
      "id": "input_bg",
      "label": "Input Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_border",
      "label": "Input Border",
      "default": "#d0c5b8"
    },
    {
      "type": "color",
      "id": "callout_bg",
      "label": "Confirmation Box Background",
      "default": "#2e112d"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Join The Game"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your 221 Moment Starts Here."
    },
    {
      "type": "text",
      "id": "prompt",
      "label": "Prompt Text",
      "default": "Tell us your greatest rugby story — a braai, a watch party, a match, a memory. The best story each week wins a box of 221."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit Button Label",
      "default": "Submit My 221 Moment"
    },
    {
      "type": "text",
      "id": "social_alt_text",
      "label": "Social Alternative Text",
      "default": "Prefer to share on social? Tag"
    },
    {
      "type": "header",
      "content": "Confirmation Message"
    },
    {
      "type": "text",
      "id": "confirmation_heading",
      "label": "Confirmation Heading",
      "default": "Now That's a 221 Story."
    },
    {
      "type": "text",
      "id": "confirmation_body",
      "label": "Confirmation Body",
      "default": "We've got yours — winners announced every Sunday."
    },
    {
      "type": "header",
      "content": "T&Cs"
    },
    {
      "type": "url",
      "id": "tcs_link",
      "label": "T&Cs Page Link"
    }
  ],
  "presets": [
    { "name": "Playbook — Submission Form" }
  ]
}
{% endschema %}
