{{ 'component-rte.css' | asset_url | stylesheet_tag }}
{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'section-main-page.css' | asset_url | stylesheet_tag }}</noscript>

<div class="page-width page-width--narrow price-overview-page">
  <h2 class="page-title price-overview-title">
    ALVI'S DRIFT PRICE OVERVIEW
  </h2>

  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
      <aside
        aria-labelledby="verticalTitle"
        class="facets-wrapper page-width{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}"
        id="main-collection-filters"
        data-id="{{ section.id }}"
      >
        {% render 'facets',
          results: collection,
          enable_filtering: section.settings.enable_filtering,
          enable_sorting: section.settings.enable_sorting,
          filter_type: section.settings.filter_type,
          collapse_on_larger_devices: section.settings.collapse_on_larger_devices,
          paginate: paginate
        %}
      </aside>
    {%- endif -%}

    <div id="ProductGridContainer" class="product-grid-container">
      {%- if collection.products.size == 0 -%}
        <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
          <div class="loading-overlay gradient"></div>
          <div class="title-wrapper center">
            <h2 class="title title--primary">
              {{ 'sections.collection_template.empty' | t }}<br>
              {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: 'underlined-link link' }}
            </h2>
          </div>
        </div>
      {%- else -%}
        <div class="collection price-list-collection-wrapper">
          <div class="loading-overlay gradient"></div>

          <div class="container-price-list wrap" id="product-grid" data-id="{{ section.id }}">
            {%- for product in collection.products -%}
              <div class="price-list box">
                <div class="product-image">
                  <a target="_blank" rel="noopener" href="{{ product.url | within: collection }}">
                    {%- if product.featured_image -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | default: product.title | escape }}"
                        loading="lazy"
                        width="{{ product.featured_image.width }}"
                        height="{{ product.featured_image.height }}"
                      >
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg product-placeholder' }}
                    {%- endif -%}
                  </a>
                </div>

                <div class="product-name">
                  <a target="_blank" rel="noopener" href="{{ product.url | within: collection }}">
                    <div class="product-title">{{ product.title }}</div>
                    {% unless product.tags contains 'Gift' %}
                      <h4>Case of 6</h4>
                    {% endunless %}
                  </a>
                </div>

                <div class="product-pr">
                  <a target="_blank" rel="noopener" href="{{ product.url | within: collection }}">
                    <p>{{ product.price | money | remove: '.00' | replace: ',', ' ' }}</p>
                    <span class="visually-hidden">{{ product.price }}</span>
                    <div class="list-btn">BUY</div>
                  </a>
                </div>
              </div>
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate, anchor: '' %}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div id="DivIdToPrint" class="print-price-list" style="display: none;">
      <table class="price-table-list" border="0" style="width: 100%;">
        <tbody>
          {%- for product in collection.products -%}
            <tr style="margin-bottom: 35px;">
              <td>
                {%- if product.featured_image -%}
                  <img
                    style="height: 100px; width: auto;"
                    src="{{ product.featured_image | image_url: width: 200 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                  >
                {%- endif -%}
              </td>
              <td><h3>{{ product.title }}</h3></td>
              <td><h2>{{ product.price | money | remove: '.00' | replace: ',', ' ' }}</h2></td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  {%- endpaginate -%}

  {% comment %}
    <div class="product-print-btn">
      <button id="btn" type="button">Print This Page</button>
    </div>
  {% endcomment %}
</div>

<style>
  body {
    background-color: #480115;
  }

  .price-overview-page.page-width--narrow {
    max-width: 100rem !important;
    padding: 0;
  }

  .price-overview-title {
    text-align: center;
    padding-bottom: 50px;
  }

  .facets-wrapper {
    padding-top: 35px;
    padding-bottom: 35px;
  }

  /* Keep Shopify facet dropdown text visible on this custom page background */
  .facets__display,
  .facets__header,
  .facets-wrap,
  .facets__list,
  .facets__item,
  .facet-checkbox,
  .facet-checkbox__text,
  .facet-checkbox__text-label,
  .facets__price,
  .facets__price .field,
  .facets__price .field__input,
  .facets__price .field__label {
    color: #404040 !important;
  }

  .facets__display {
    background: #fff !important;
    border: 1px solid rgba(0, 0, 0, 0.15);
  }

  .facets__item,
  .facets__item label,
  .facet-checkbox {
    visibility: visible !important;
    opacity: 1 !important;
  }

  .facets__price .field__input {
    background: #fff !important;
    border: 1px solid rgba(0, 0, 0, 0.25) !important;
  }

  .price-list {
    display: flex;
    gap: 20px;
    background-color: #e4decd;
    border-radius: 3px;
    padding: 20px;
    margin: 30px;
    align-items: center;
  }

  .price-list a {
    text-decoration: none;
  }

  .price-list .product-image {
    width: 15%;
  }

  .product-image img,
  .product-placeholder {
    height: 110px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .product-name {
    width: 68%;
    padding-left: 0;
  }

  .product-title {
    color: #404040;
    font-size: 20px;
    font-weight: 600;
    padding-bottom: 20px;
    line-height: 23px;
  }

  .product-name h4 {
    color: #000;
    margin: 0;
  }

  .product-pr {
    width: 17%;
    text-align: center;
  }

  .product-pr p {
    color: #000;
    margin: 0 0 20px;
  }

  .list-btn {
    padding: 5px 10px;
    border-radius: 3px;
    border: 1px solid #c65336;
    background: #c65336;
    color: #fff;
    text-align: center;
    font-size: 14px;
    text-transform: uppercase;
    line-height: 28px;
    display: inline-block;
  }

  .product-print-btn {
    text-align: center;
    margin: 30px 0 50px;
  }
.facet-filters__sort {
    padding-left: 10px;
    padding-right: 0.75rem;
}
  button#btn {
    cursor: pointer;
    color: var(--headingColor);
    font: bold 14px/100% var(--metropolis);
    letter-spacing: 0.7px;
    text-align: center;
    padding: 11px 32px;
    display: inline-block;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 50ms linear;
    background-color: transparent;
    border: 1px solid var(--headingColor);
  }

  @media only screen and (max-width: 850px) {
    .price-list .product-name {
      width: 55%;
    }

    .product-pr {
      width: 30%;
      text-align: center;
    }
  }

  @media only screen and (max-width: 500px) {
    .price-list {
      margin: 20px;
      gap: 12px;
      font-size: 10px;
    }

    .price-list .product-image {
      width: auto;
    }

    .product-image img,
    .product-placeholder {
      height: 120px;
    }

    .product-pr {
      width: 30%;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Price product list",
  "class": "spaced-section collection-grid-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 100,
      "step": 4,
      "default": 100,
      "label": "Products per page"
    },
    {
      "type": "header",
      "content": "Product cards"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "adapt",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "add_image_padding",
      "default": false,
      "label": "Add image padding"
    },
    {
      "type": "checkbox",
      "id": "show_image_outline",
      "default": true,
      "label": "Show image outline"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating",
      "info": "To display a rating, add a product rating app."
    },
    {
      "type": "header",
      "content": "Filtering and sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "Enable filtering"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "Enable sorting"
    },
    {
      "type": "select",
      "id": "filter_type",
      "options": [
        {
          "value": "horizontal",
          "label": "Horizontal"
        },
        {
          "value": "vertical",
          "label": "Vertical"
        },
        {
          "value": "drawer",
          "label": "Drawer"
        }
      ],
      "default": "horizontal",
      "label": "Desktop filter layout"
    },
    {
      "type": "checkbox",
      "id": "collapse_on_larger_devices",
      "default": false,
      "label": "Collapse filters on larger screens"
    }
  ]
}
{% endschema %}
