<style>
  .playbook-wine {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .playbook-wine__inner {
    max-width: 1294px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .playbook-wine__header {
    text-align: center;
    margin-bottom: 56px;
  }
  .playbook-wine__eyebrow {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c65336;
    margin-bottom: 14px;
    display: block;
  }
  .playbook-wine__heading {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(28px, 4vw, 52px);
    color: {{ section.settings.heading_color }};
    line-height: 1.05;
    margin: 0 0 14px;
    font-weight: 400;
  }
  .playbook-wine__subhead {
    font-family: Metropolis, sans-serif;
    font-size: 16px;
    color: {{ section.settings.text_color }};
    line-height: 1.6;
    margin: 0 auto;
    max-width: 600px;
    opacity: 0.8;
  }
  /* Cards */
  .playbook-wine__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }
  .playbook-wine__card {
    background: {{ section.settings.card_bg }};
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.2s;
  }
  .playbook-wine__card:hover { transform: translateY(-4px); }
  .playbook-wine__card-image {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #ffffff;
    flex-shrink: 0;
  }
  .playbook-wine__card-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    padding: 20px 16px 0;
    box-sizing: border-box;
    display: block;
  }
  .playbook-wine__card-image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #2e112d, #480135);
  }
  .playbook-wine__card-image-placeholder span {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    color: rgba(248,242,230,0.3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .playbook-wine__percys-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #c65336;
    color: #fff;
    font-family: Metropolis, sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 20px;
  }
  .playbook-wine__card-body {
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .playbook-wine__occasion {
    font-family: Metropolis, sans-serif;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c65336;
    margin-bottom: 8px;
    display: block;
    font-weight: 600;
  }
  .playbook-wine__varietal {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: 22px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 400;
    line-height: 1.15;
  }
  .playbook-wine__tasting-note {
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    color: {{ section.settings.text_color }};
    line-height: 1.65;
    margin: 0 0 20px;
    flex: 1;
    opacity: 0.8;
  }
  .playbook-wine__shop-link {
    background: #c65336;
    color: #fff !important;
    padding: 12px 22px;
    border-radius: 25px;
    font-family: Metropolis, sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: opacity 0.2s;
    display: block;
    text-align: center;
  }
  .playbook-wine__shop-link:hover { opacity: 0.85; }
  /* Range CTA */
  .playbook-wine__range-cta {
    text-align: center;
  }
  .playbook-wine__range-link {
    background: transparent;
    color: {{ section.settings.heading_color }} !important;
    padding: 15px 40px;
    border-radius: 25px;
    border: 1px solid {{ section.settings.heading_color }};
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
  }
  .playbook-wine__range-link:hover {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }} !important;
  }
  @media (max-width: 1099px) {
    .playbook-wine__grid { grid-template-columns: 1fr 1fr; gap: 16px; }
  }
  @media (max-width: 499px) {
    .playbook-wine__grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .playbook-wine__card-image img { padding: 12px 10px 0; }
  }
</style>

<section id="playbook-wine" class="playbook-wine">
  <div class="playbook-wine__inner">
    <div class="playbook-wine__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="playbook-wine__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="playbook-wine__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subhead != blank -%}
        <p class="playbook-wine__subhead">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </div>

    <div class="playbook-wine__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'wine_card' -%}
          <div class="playbook-wine__card" {{ block.shopify_attributes }}>
            <div class="playbook-wine__card-image">
              {%- if block.settings.bottle_image != blank -%}
                <img
                  src="{{ block.settings.bottle_image | img_url: 'large' }}"
                  alt="{{ block.settings.varietal }}"
                  loading="lazy"
                >
              {%- else -%}
                <div class="playbook-wine__card-image-placeholder">
                  <span>Bottle image</span>
                </div>
              {%- endif -%}
              {%- if block.settings.percys_pick -%}
                <span class="playbook-wine__percys-badge">Percy's Pick</span>
              {%- endif -%}
            </div>
            <div class="playbook-wine__card-body">
              {%- if block.settings.occasion != blank -%}
                <span class="playbook-wine__occasion">{{ block.settings.occasion }}</span>
              {%- endif -%}
              <h3 class="playbook-wine__varietal">{{ block.settings.varietal }}</h3>
              {%- if block.settings.tasting_note != blank -%}
                <p class="playbook-wine__tasting-note">{{ block.settings.tasting_note }}</p>
              {%- endif -%}
              {%- if block.settings.shop_link != blank -%}
                <a href="{{ block.settings.shop_link }}" class="playbook-wine__shop-link">
                  {{ section.settings.shop_cta_label | default: 'Shop Now' }}
                </a>
              {%- else -%}
                <a href="{{ section.settings.range_link | default: '/collections/221-range' }}" class="playbook-wine__shop-link">
                  {{ section.settings.shop_cta_label | default: 'Shop Now' }}
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.range_cta_text != blank -%}
      <div class="playbook-wine__range-cta">
        <a href="{{ section.settings.range_link }}" class="playbook-wine__range-link">{{ section.settings.range_cta_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
