      "label": "Image Overlay Opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 60,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Colour",
      "default": "#f8f2e6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text",
      "default": "#f8f2e6"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Grand Prize"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Greatest Rivalry Watch Party with Percy."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Description",
      "default": "The All Blacks series. Percy Tau. The ultimate 221 experience for the ultimate fan. One grand prize winner joins Percy for a Watch Party in New Zealand — details announced late June."
    },
    {
      "type": "text",
      "id": "entry_callout",
      "label": "Entry Callout",
      "default": "Every weekly submission is an automatic entry into the grand prize draw. <strong>The more you share, the better your chances.</strong>"
