<style>
  .playbook-prize {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }
  .playbook-prize__bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .playbook-prize__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .playbook-prize__bg-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }
  .playbook-prize__inner {
    position: relative;
    z-index: 2;
    max-width: 1294px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .playbook-prize__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .playbook-prize__content-col {}
  .playbook-prize__eyebrow {
    font-family: Metropolis, sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c65336;
    margin-bottom: 14px;
    display: block;
  }
  .playbook-prize__heading {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: clamp(30px, 4vw, 54px);
    color: {{ section.settings.heading_color }};
    line-height: 1.05;
    margin: 0 0 24px;
    font-weight: 400;
  }
  .playbook-prize__body {
    font-family: Metropolis, sans-serif;
    font-size: 16px;
    color: {{ section.settings.text_color }};
    line-height: 1.75;
    margin: 0 0 28px;
    opacity: 0.88;
  }
  .playbook-prize__entry-callout {
    background: rgba(198, 83, 54, 0.15);
    border: 1px solid rgba(198, 83, 54, 0.4);
    border-radius: 6px;
    padding: 18px 22px;
    margin-bottom: 32px;
  }
  .playbook-prize__entry-callout p {
    font-family: Metropolis, sans-serif;
    font-size: 14px;
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.5;
  }
  .playbook-prize__entry-callout strong { color: #c65336; }
  .playbook-prize__countdown {
    display: none;
  }
  .playbook-prize__countdown.is-active {
    display: flex;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .playbook-prize__countdown-unit {
    text-align: center;
  }
  .playbook-prize__countdown-number {
    font-family: Moriarty, Metropolis, sans-serif;
    font-size: 48px;
    color: {{ section.settings.heading_color }};
    line-height: 1;
    display: block;
    font-weight: 400;
  }
  .playbook-prize__countdown-label {
    font-family: Metropolis, sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    opacity: 0.5;
  }
  .playbook-prize__cta {
    background: #c65336;
    color: #fff !important;
    padding: 16px 38px;
    border-radius: 25px;
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: opacity 0.2s;
    display: inline-block;
  }
  .playbook-prize__cta:hover { opacity: 0.85; }
  .playbook-prize__image-col {}
  .playbook-prize__image img {
    width: 100%;
    height: auto;
    display: block;
    clip-path: polygon(0 0,100% 0,100% 96%,0 100%);
  }
  .playbook-prize__image-placeholder {
    aspect-ratio: 3/4;
    background: linear-gradient(160deg, #480135 0%, #1a0a1a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    clip-path: polygon(0 0,100% 0,100% 96%,0 100%);
  }
  .playbook-prize__image-placeholder span {
    font-family: Metropolis, sans-serif;
    font-size: 13px;
    color: rgba(248,242,230,0.4);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  @media (max-width: 899px) {
    .playbook-prize__layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .playbook-prize__image-col { order: -1; }
  }
</style>

<section id="playbook-prize" class="playbook-prize">
  {%- if section.settings.bg_image != blank -%}
    <div class="playbook-prize__bg-image">
      <img
        src="{{ section.settings.bg_image | img_url: 'master' }}"
        alt=""
        loading="lazy"
        role="presentation"
      >
    </div>
    <div class="playbook-prize__bg-overlay"></div>
  {%- endif -%}

  <div class="playbook-prize__inner">
    <div class="playbook-prize__layout">
      <div class="playbook-prize__content-col">
        {%- if section.settings.eyebrow != blank -%}
          <span class="playbook-prize__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="playbook-prize__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}
          <p class="playbook-prize__body">{{ section.settings.body }}</p>
        {%- endif -%}

        {%- if section.settings.entry_callout != blank -%}
          <div class="playbook-prize__entry-callout">
            <p>{{ section.settings.entry_callout }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.show_countdown -%}
          <div class="playbook-prize__countdown is-active" id="playbook-countdown" data-target="{{ section.settings.countdown_date }}">
            <div class="playbook-prize__countdown-unit">
              <span class="playbook-prize__countdown-number" id="pb-cd-days">00</span>
              <span class="playbook-prize__countdown-label">Days</span>
            </div>
            <div class="playbook-prize__countdown-unit">
              <span class="playbook-prize__countdown-number" id="pb-cd-hours">00</span>
              <span class="playbook-prize__countdown-label">Hours</span>
            </div>
            <div class="playbook-prize__countdown-unit">
              <span class="playbook-prize__countdown-number" id="pb-cd-mins">00</span>
              <span class="playbook-prize__countdown-label">Minutes</span>
            </div>
            <div class="playbook-prize__countdown-unit">
              <span class="playbook-prize__countdown-number" id="pb-cd-secs">00</span>
              <span class="playbook-prize__countdown-label">Seconds</span>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: '#playbook-form' }}" class="playbook-prize__cta">{{ section.settings.cta_text }}</a>
        {%- endif -%}
      </div>

      <div class="playbook-prize__image-col">
        {%- if section.settings.image != blank -%}
          <div class="playbook-prize__image">
            <img
              src="{{ section.settings.image | img_url: 'large' }}"
              alt="{{ section.settings.image.alt | default: 'Grand Prize' }}"
              loading="lazy"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
            >
          </div>
        {%- else -%}
          <div class="playbook-prize__image-placeholder">
            <span>Prize image</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{%- if section.settings.show_countdown and section.settings.countdown_date != blank -%}
<script>
  (function() {
    var target = new Date('{{ section.settings.countdown_date }}').getTime();
    function tick() {
      var now = new Date().getTime();
      var diff = target - now;
      if (diff <= 0) return;
      var d = document.getElementById('pb-cd-days');
      var h = document.getElementById('pb-cd-hours');
      var m = document.getElementById('pb-cd-mins');
      var s = document.getElementById('pb-cd-secs');
      if (!d) return;
      d.textContent = String(Math.floor(diff / 86400000)).padStart(2, '0');
      h.textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
      m.textContent = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
      s.textContent = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Playbook — Grand Prize",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Background"
