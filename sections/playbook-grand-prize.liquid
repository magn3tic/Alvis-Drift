    {
      "type": "text",
      "id": "countdown_date",
      "label": "Countdown Target Date",
      "info": "ISO format: 2026-08-07T18:00:00+02:00",
      "default": "2026-08-07T18:00:00+02:00"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Submit Your Moment to Enter"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Prize / Percy Image"
    }
  ],
  "presets": [
    { "name": "Playbook — Grand Prize" }
  ]
}
{% endschema %}
